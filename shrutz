#!/usr/bin/env bash
# ┌─────────────────────────────────────────────────────────────┐
# │  shrutz — active-time wallpaper rotator                     │
# │                                                             │
# │  Script  : ~/.local/bin/shrutz                             │
# │  Sets    : ~/.local/lib/shrutz/wallpapers/<set>/           │
# │  State   : ~/.local/lib/shrutz/state                       │
# │  Log     : ~/.local/lib/shrutz/shrutz.log                  │
# │  Agent   : ~/.local/etc/launchd/local.shrutz.plist         │
# │            (symlinked → ~/Library/LaunchAgents/)           │
# └─────────────────────────────────────────────────────────────┘

# ── Paths ──────────────────────────────────────────────────────
SHRUTZ_LIB="$HOME/.local/lib/shrutz"
WALLPAPER_BASE="$SHRUTZ_LIB/wallpapers"
STATE_FILE="$SHRUTZ_LIB/state"
LOG_FILE="$SHRUTZ_LIB/shrutz.log"
WALLPAPER_STORE="$HOME/Library/Application Support/com.apple.wallpaper/Store/Index.plist"

# ── Tunables ───────────────────────────────────────────────────
ACTIVE_MINS=30        # minutes of real use before switching
IDLE_THRESHOLD=60     # seconds without input → considered away
CHECK_EVERY=30        # how often the loop wakes up (seconds)

# ── Derived ────────────────────────────────────────────────────
ACTIVE_SECS_NEEDED=$(( ACTIVE_MINS * 60 ))

# ══════════════════════════════════════════════════════════════════
# SHARED UTILITIES
# ══════════════════════════════════════════════════════════════════

log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

die() {
    printf 'shrutz: %s\n' "$*" >&2
    exit 1
}

# Load state into globals. Safe to call multiple times.
load_state() {
    CURRENT_INDEX=0
    ACTIVE_SECONDS=0
    ACTIVE_SET="default"
    PAUSED=0
    PLAY_ORDER=""        # space-separated shuffle order; empty = sequential
    SHRUTZ_REPO=""       # path to the git repo, set by installer
    [[ -f "$STATE_FILE" ]] && source "$STATE_FILE"
}

save_state() {
    printf 'CURRENT_INDEX=%d\nACTIVE_SECONDS=%d\nACTIVE_SET=%s\nPAUSED=%d\nPLAY_ORDER=%s\nSHRUTZ_REPO=%s\n' \
        "$CURRENT_INDEX" "$ACTIVE_SECONDS" "$ACTIVE_SET" "$PAUSED" \
        "$PLAY_ORDER" "$SHRUTZ_REPO" > "$STATE_FILE"
}

# Resolve the active wallpaper directory from state.
active_set_dir() {
    echo "$WALLPAPER_BASE/$ACTIVE_SET"
}

# Read the __init__ field by key from a set directory.
# Usage: init_field <set_dir> <key>
init_field() {
    local dir="$1" key="$2"
    local init="$dir/__init__"
    [[ -f "$init" ]] && grep "^${key}=" "$init" | cut -d= -f2- || echo ""
}

# Count images in a set directory (excludes __init__).
count_images() {
    local dir="$1"
    find "$dir" -maxdepth 1 \
        \( -iname "*.jpg" -o -iname "*.jpeg" \
        -o -iname "*.png" -o -iname "*.heic" \
        -o -iname "*.webp" \) 2>/dev/null | wc -l | tr -d ' '
}

# Check a set directory exists and is non-empty.
assert_set_exists() {
    local name="$1"
    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]]     || die "set '$name' does not exist"
    (( $(count_images "$dir") > 0 )) || die "set '$name' has no images"
}

# Write (or overwrite) the __init__ metadata file for a set.
write_init() {
    local dir="$1" name="$2"
    local count
    count=$(count_images "$dir")
    cat > "$dir/__init__" << EOF
name=$name
created=$(date '+%Y-%m-%d %H:%M:%S')
images=$count
EOF
}

# Refresh the image count in an existing __init__ without touching other fields.
refresh_init_count() {
    local dir="$1"
    local count
    count=$(count_images "$dir")
    local init="$dir/__init__"
    if [[ -f "$init" ]]; then
        local tmp
        tmp=$(grep -v '^images=' "$init")
        printf '%s\nimages=%s\n' "$tmp" "$count" > "$init"
    fi
}

# Get the PID of the running daemon (launchd-managed shrutz process).
daemon_pid() {
    pgrep -f "shrutz daemon" 2>/dev/null | head -1
}

# Signal the daemon to restart via launchd (SIGTERM → launchd restarts it).
restart_daemon() {
    local pid
    pid=$(daemon_pid)
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null
    # launchd KeepAlive=true restarts it automatically within ~1s
}

# ══════════════════════════════════════════════════════════════════
# DAEMON INTERNALS
# ══════════════════════════════════════════════════════════════════

idle_seconds() {
    ioreg -c IOHIDSystem \
        | awk '/HIDIdleTime/ { print int($NF / 1000000000); exit }'
}

current_wallpaper() {
    osascript -e \
        'tell application "System Events" to get picture of desktop 1' \
        2>/dev/null | tr -d '\n'
}

apply_to_current_space() {
    local path="$1"
    osascript -e \
        "tell application \"System Events\"
            tell every desktop
                set picture to \"$path\"
            end tell
        end tell" 2>/dev/null
}

write_index_plist() {
    local path="$1"
    local store="$WALLPAPER_STORE"

    WP_PATH="$path" WP_STORE="$store" python3 << 'PYEOF'
import plistlib, datetime, os, sys

path  = os.environ['WP_PATH']
store = os.environ['WP_STORE']

config = plistlib.dumps(
    {'type': 'imageFile', 'url': {'relative': f'file://{path}'}},
    fmt=plistlib.FMT_BINARY
)
now = datetime.datetime.now()

def patch_desktop(desktop):
    content = desktop.get('Content', {})
    for choice in content.get('Choices', []):
        if choice.get('Provider') == 'com.apple.wallpaper.choice.image':
            choice['Configuration'] = config
            choice['Files'] = []
    desktop['LastSet'] = now

def patch_space(space):
    default = space.get('Default', {})
    if 'Desktop' in default:
        patch_desktop(default['Desktop'])
    for disp in space.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

try:
    with open(store, 'rb') as f:
        d = plistlib.load(f)

    if 'Desktop' in d.get('SystemDefault', {}):
        patch_desktop(d['SystemDefault']['Desktop'])

    for space in d.get('Spaces', {}).values():
        patch_space(space)

    for disp in d.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

    with open(store, 'wb') as f:
        plistlib.dump(d, f, fmt=plistlib.FMT_BINARY)

    print('ok')
except Exception as e:
    print(f'error: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
}

apply_all_spaces() {
    local path="$1"

    if [[ ! -f "$WALLPAPER_STORE" ]]; then
        apply_to_current_space "$path"
        log "Wallpaper store not found — applied to current space only (poll will correct others)"
        return
    fi

    if write_index_plist "$path"; then
        launchctl kickstart -k "gui/$(id -u)/com.apple.wallpaper.agent" 2>/dev/null || \
            killall WallpaperAgent 2>/dev/null || true
        sleep 1
        apply_to_current_space "$path"
        log "Applied to all spaces via Index.plist + agent reload"
    else
        apply_to_current_space "$path"
        log "Index.plist write failed — applied to current space only (poll will correct others)"
    fi
}

# ══════════════════════════════════════════════════════════════════
# DAEMON — main loop
# ══════════════════════════════════════════════════════════════════

run_daemon() {
    load_state

    WALLPAPER_DIR="$WALLPAPER_BASE/$ACTIVE_SET"

    # Build wallpaper list (always sorted — shuffle reorders via PLAY_ORDER)
    WALLPAPERS=()
    while IFS= read -r -d '' f; do
        WALLPAPERS+=("$f")
    done < <(find "$WALLPAPER_DIR" -maxdepth 1 \
        \( -iname "*.jpg"  -o -iname "*.jpeg" \
        -o -iname "*.png"  -o -iname "*.heic" \
        -o -iname "*.webp" \) \
        -print0 | sort -z)

    TOTAL=${#WALLPAPERS[@]}
    if (( TOTAL == 0 )); then
        log "ERROR: no images found in $WALLPAPER_DIR — exiting"
        exit 1
    fi

    (( CURRENT_INDEX >= TOTAL )) && CURRENT_INDEX=0

    # ── Shuffle setup ──────────────────────────────────────────
    # If the active set has shuffle=true in __init__, we maintain
    # a PLAY_ORDER array — a permutation of 0..TOTAL-1 indices.
    # CURRENT_INDEX then points into PLAY_ORDER, not directly into WALLPAPERS.
    # On exhaustion we reshuffle. Sequential sets leave PLAY_ORDER empty.

    SHUFFLE_MODE=0
    local set_shuffle
    set_shuffle=$(init_field "$WALLPAPER_DIR" "shuffle")
    [[ "$set_shuffle" == "true" ]] && SHUFFLE_MODE=1

    # Rebuild or validate PLAY_ORDER
    _build_play_order() {
        PLAY_ORDER=$(python3 -c "
import random, sys
n = int(sys.argv[1])
order = list(range(n))
random.shuffle(order)
print(' '.join(map(str, order)))
" "$TOTAL")
        log "shuffle: new play order generated for $TOTAL images"
    }

    if (( SHUFFLE_MODE == 1 )); then
        local order_count
        order_count=$(echo "$PLAY_ORDER" | wc -w | tr -d ' ')
        # Regenerate if empty or stale (different total than current)
        if [[ -z "$PLAY_ORDER" ]] || (( order_count != TOTAL )); then
            _build_play_order
            CURRENT_INDEX=0
        fi
    fi

    # Resolve the actual wallpaper path from index (shuffle-aware)
    _resolve_wallpaper() {
        if (( SHUFFLE_MODE == 1 )); then
            local order=($PLAY_ORDER)
            echo "${WALLPAPERS[${order[$CURRENT_INDEX]}]}"
        else
            echo "${WALLPAPERS[$CURRENT_INDEX]}"
        fi
    }

    # Advance index; reshuffle when the shuffle set wraps around
    _advance_index() {
        (( CURRENT_INDEX = (CURRENT_INDEX + 1) % TOTAL ))
        if (( SHUFFLE_MODE == 1 )) && (( CURRENT_INDEX == 0 )); then
            _build_play_order
        fi
    }

    _retreat_index() {
        (( CURRENT_INDEX = (CURRENT_INDEX - 1 + TOTAL) % TOTAL ))
    }

    # ── Signal handlers ────────────────────────────────────────
    trap '_sig_next' USR1
    trap '_sig_prev' USR2
    trap '_sig_pause_toggle' HUP

    _sig_next() {
        _advance_index
        local wp; wp=$(_resolve_wallpaper)
        apply_all_spaces "$wp"
        log "next → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp") (timer unchanged)"
        save_state
    }

    _sig_prev() {
        _retreat_index
        local wp; wp=$(_resolve_wallpaper)
        apply_all_spaces "$wp"
        log "prev → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp") (timer unchanged)"
        save_state
    }

    _sig_pause_toggle() {
        if (( PAUSED == 0 )); then
            PAUSED=1
            log "paused — active timer frozen at ${ACTIVE_SECONDS}s"
        else
            PAUSED=0
            log "resumed — active timer continuing from ${ACTIVE_SECONDS}s"
        fi
        save_state
    }

    local shuffle_label=""
    (( SHUFFLE_MODE == 1 )) && shuffle_label=" [shuffle]"
    log "shrutz started — set='$ACTIVE_SET'${shuffle_label} $TOTAL wallpapers, rotate every ${ACTIVE_MINS}m active use"
    [[ "$PAUSED" == "1" ]] && log "note: starting in paused state"

    local current_wp; current_wp=$(_resolve_wallpaper)
    apply_all_spaces "$current_wp"
    log "Restored → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$current_wp")"

    while true; do
        sleep "$CHECK_EVERY"

        idle=$(idle_seconds)

        if (( idle < IDLE_THRESHOLD )) && (( PAUSED == 0 )); then
            (( ACTIVE_SECONDS += CHECK_EVERY ))

            if (( ACTIVE_SECONDS >= ACTIVE_SECS_NEEDED )); then
                _advance_index
                local wp; wp=$(_resolve_wallpaper)
                apply_all_spaces "$wp"
                ACTIVE_SECONDS=0
                log "Switched → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp")"

            else
                local expected; expected=$(_resolve_wallpaper)
                local current; current=$(current_wallpaper)
                if [[ "$current" != "$expected" ]]; then
                    apply_to_current_space "$expected"
                    log "Mismatch on active space — reapplied: $(basename "$expected")"
                fi
            fi
        fi

        save_state
    done
}

# ══════════════════════════════════════════════════════════════════
# CLI COMMANDS
# ══════════════════════════════════════════════════════════════════

cmd_status() {
    launchctl list | grep shrutz || echo "shrutz: daemon not running"
}

cmd_log() {
    tail -f "$LOG_FILE"
}

cmd_start() {
    launchctl load "$HOME/Library/LaunchAgents/local.shrutz.plist"
}

cmd_stop() {
    launchctl unload "$HOME/Library/LaunchAgents/local.shrutz.plist"
}

# ── shrutz sets ────────────────────────────────────────────────
cmd_sets() {
    load_state
    local found=0
    printf '\n  %-24s  %-8s  %-20s  %s\n' "NAME" "IMAGES" "CREATED" ""
    printf '  %-24s  %-8s  %-20s\n' "────────────────────────" "────────" "────────────────────"
    for dir in "$WALLPAPER_BASE"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        local images created marker
        images=$(count_images "$dir")
        created=$(init_field "$dir" "created")
        [[ "$name" == "$ACTIVE_SET" ]] && marker=" ◀ active" || marker=""
        printf '  %-24s  %-8s  %-20s  %s\n' "$name" "$images" "$created" "$marker"
        found=1
    done
    (( found == 0 )) && echo "  (no sets found — create one with: shrutz set create <name>)"
    echo ""
}

# ── shrutz set <subcommand> ────────────────────────────────────
cmd_set() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create)  cmd_set_create "$@" ;;
        delete)  cmd_set_delete "$@" ;;
        rename)  cmd_set_rename "$@" ;;
        info)    cmd_set_info   "$@" ;;
        shuffle) cmd_set_shuffle "$@" ;;
        *)
            echo "Usage: shrutz set <create|delete|rename|info|shuffle> [args]"
            exit 1
            ;;
    esac
}

cmd_set_create() {
    local name="${1:-}"
    local src="${2:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set create <name> [source-path]"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] && die "set '$name' already exists"

    mkdir -p "$dir"
    write_init "$dir" "$name"
    echo "shrutz: created set '$name'"

    if [[ -n "$src" ]]; then
        echo "shrutz: importing from '$src'..."
        _import_into "$src" "$dir"
        refresh_init_count "$dir"
        echo "shrutz: done — $(count_images "$dir") images in '$name'"
    fi
}

cmd_set_delete() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set delete <name>"

    load_state
    [[ "$name" == "$ACTIVE_SET" ]] && die "cannot delete the active set ('$name' is in use — switch first)"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    printf 'shrutz: delete set "%s" and all its images? [y/N] ' "$name"
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "shrutz: cancelled"; exit 0; }

    rm -rf "$dir"
    echo "shrutz: deleted set '$name'"
}

cmd_set_rename() {
    local old="${1:-}" new="${2:-}"
    [[ -z "$old" || -z "$new" ]] && die "Usage: shrutz set rename <old> <new>"

    local old_dir="$WALLPAPER_BASE/$old"
    local new_dir="$WALLPAPER_BASE/$new"
    [[ -d "$old_dir" ]] || die "set '$old' does not exist"
    [[ -d "$new_dir" ]] && die "set '$new' already exists"

    mv "$old_dir" "$new_dir"

    # Patch name field in __init__
    local init="$new_dir/__init__"
    if [[ -f "$init" ]]; then
        local tmp
        tmp=$(grep -v '^name=' "$init")
        printf '%s\nname=%s\n' "$tmp" "$new" > "$init"
    fi

    load_state
    if [[ "$ACTIVE_SET" == "$old" ]]; then
        ACTIVE_SET="$new"
        save_state
        echo "shrutz: renamed '$old' → '$new' (active set updated)"
        restart_daemon
    else
        echo "shrutz: renamed '$old' → '$new'"
    fi
}

cmd_set_info() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set info <name>"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    load_state

    local images created disksize active_marker
    images=$(count_images "$dir")
    created=$(init_field "$dir" "created")
    disksize=$(du -sh "$dir" 2>/dev/null | cut -f1)
    [[ "$name" == "$ACTIVE_SET" ]] && active_marker=" (active)" || active_marker=""

    echo ""
    echo "  Set: $name$active_marker"
    echo "  Created:    $created"
    echo "  Images:     $images"
    echo "  Disk usage: $disksize"

    if [[ "$name" == "$ACTIVE_SET" ]]; then
        local mins_done mins_left
        mins_done=$(( ACTIVE_SECONDS / 60 ))
        mins_left=$(( (ACTIVE_SECS_NEEDED - ACTIVE_SECONDS) / 60 ))
        echo "  Progress:   ${mins_done}m active / ${ACTIVE_MINS}m needed (${mins_left}m remaining)"
        echo "  Position:   image $(( CURRENT_INDEX + 1 )) of $images"
    fi
    echo ""
}

cmd_set_shuffle() {
    local name="${1:-}" mode="${2:-}"
    [[ -z "$name" || -z "$mode" ]] && die "Usage: shrutz set shuffle <name> <on|off>"
    [[ "$mode" != "on" && "$mode" != "off" ]] && die "mode must be 'on' or 'off'"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    local init="$dir/__init__"
    local flag; [[ "$mode" == "on" ]] && flag="true" || flag="false"

    if [[ -f "$init" ]]; then
        if grep -q '^shuffle=' "$init"; then
            local tmp; tmp=$(grep -v '^shuffle=' "$init")
            printf '%s\nshuffle=%s\n' "$tmp" "$flag" > "$init"
        else
            printf 'shuffle=%s\n' "$flag" >> "$init"
        fi
    else
        printf 'name=%s\ncreated=%s\nimages=%s\nshuffle=%s\n' \
            "$name" "$(date '+%Y-%m-%d %H:%M:%S')" "$(count_images "$dir")" "$flag" > "$init"
    fi

    echo "shrutz: shuffle $mode for set '$name'"

    load_state
    if [[ "$ACTIVE_SET" == "$name" ]]; then
        # Clear stale play order so daemon regenerates on restart
        PLAY_ORDER=""
        save_state
        restart_daemon
        echo "shrutz: daemon restarted with shuffle $mode"
    fi
}

# ── shrutz switch ──────────────────────────────────────────────
cmd_switch() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz switch <set>"

    assert_set_exists "$name"
    load_state

    if [[ "$ACTIVE_SET" == "$name" ]]; then
        echo "shrutz: '$name' is already the active set"
        exit 0
    fi

    # Preserve ACTIVE_SECONDS — the timer is never touched by switch
    ACTIVE_SET="$name"
    CURRENT_INDEX=0
    save_state

    restart_daemon
    echo "shrutz: switched to set '$name' (timer continues from ${ACTIVE_SECONDS}s)"
}

# ── shrutz next ───────────────────────────────────────────────
cmd_next() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    kill -USR1 "$pid"
    echo "shrutz: next wallpaper (timer unchanged)"
}

# ── shrutz prev ───────────────────────────────────────────────
cmd_prev() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    kill -USR2 "$pid"
    echo "shrutz: previous wallpaper (timer unchanged)"
}

# ── shrutz pause / resume ─────────────────────────────────────
cmd_pause() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    load_state
    (( PAUSED == 1 )) && { echo "shrutz: already paused — use 'shrutz resume'"; exit 0; }
    kill -HUP "$pid"
    echo "shrutz: paused"
}

cmd_resume() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    load_state
    (( PAUSED == 0 )) && { echo "shrutz: not paused — use 'shrutz pause'"; exit 0; }
    kill -HUP "$pid"
    echo "shrutz: resumed"
}

# ── shrutz now ────────────────────────────────────────────────
cmd_now() {
    load_state

    local wallpaper_dir="$WALLPAPER_BASE/$ACTIVE_SET"
    local total
    total=$(count_images "$wallpaper_dir")

    local current_name="(unknown)"
    if (( total > 0 )); then
        # Rebuild sorted list to resolve name from index
        local files=()
        while IFS= read -r -d '' f; do
            files+=("$f")
        done < <(find "$wallpaper_dir" -maxdepth 1 \
            \( -iname "*.jpg" -o -iname "*.jpeg" \
            -o -iname "*.png" -o -iname "*.heic" \
            -o -iname "*.webp" \) \
            -print0 | sort -z)
        (( CURRENT_INDEX < ${#files[@]} )) && \
            current_name=$(basename "${files[$CURRENT_INDEX]}")
    fi

    local mins_done mins_left
    mins_done=$(( ACTIVE_SECONDS / 60 ))
    mins_left=$(( (ACTIVE_SECS_NEEDED - ACTIVE_SECONDS) / 60 ))
    local paused_label=""
    (( PAUSED == 1 )) && paused_label=" [PAUSED]"

    echo ""
    echo "  Wallpaper : $current_name"
    echo "  Set       : $ACTIVE_SET"
    echo "  Position  : $(( CURRENT_INDEX + 1 )) of $total"
    echo "  Timer     : ${mins_done}m active / ${ACTIVE_MINS}m needed (${mins_left}m to next)${paused_label}"
    echo ""
}

# ── shrutz config ─────────────────────────────────────────────
cmd_config() {
    local script="$HOME/.local/bin/shrutz"
    local key="${1:-}" val="${2:-}"

    if [[ -z "$key" ]]; then
        # Pretty-print current tunables
        echo ""
        echo "  Tunables (edit with: shrutz config <key> <value>)"
        echo ""
        grep -E '^(ACTIVE_MINS|IDLE_THRESHOLD|CHECK_EVERY)=' "$script" | \
        while IFS='=' read -r k v; do
            # Strip inline comment
            v="${v%%#*}"
            v="${v%"${v##*[![:space:]]}"}"  # rtrim
            case "$k" in
                ACTIVE_MINS)     printf '  %-20s = %s  (minutes active before switching)\n' "$k" "$v" ;;
                IDLE_THRESHOLD)  printf '  %-20s = %s  (seconds idle before pausing timer)\n' "$k" "$v" ;;
                CHECK_EVERY)     printf '  %-20s = %s  (poll interval in seconds)\n' "$k" "$v" ;;
            esac
        done
        echo ""
        return
    fi

    # Validate key
    case "$key" in
        ACTIVE_MINS|IDLE_THRESHOLD|CHECK_EVERY) ;;
        *) die "unknown config key '$key' — valid keys: ACTIVE_MINS, IDLE_THRESHOLD, CHECK_EVERY" ;;
    esac

    [[ -z "$val" ]] && die "Usage: shrutz config <key> <value>"
    [[ "$val" =~ ^[0-9]+$ ]] || die "value must be a positive integer"

    # In-place sed edit on the script
    sed -i '' "s/^${key}=[0-9]*/${key}=${val}/" "$script"
    echo "shrutz: $key set to $val"

    # Restart daemon so it picks up new tunables
    restart_daemon
    echo "shrutz: daemon restarted"
}

# ── shrutz stats ──────────────────────────────────────────────
cmd_stats() {
    load_state

    local total_switches uptime_line daemon_start uptime_str
    total_switches=$(grep -c 'Switched →' "$LOG_FILE" 2>/dev/null || echo 0)

    # First log line gives us daemon birth timestamp
    daemon_start=$(grep 'shrutz started' "$LOG_FILE" 2>/dev/null | tail -1 | \
        grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | \
        tr -d '[]')

    if [[ -n "$daemon_start" ]]; then
        local start_epoch now_epoch elapsed_secs
        start_epoch=$(date -j -f '%Y-%m-%d %H:%M:%S' "$daemon_start" '+%s' 2>/dev/null || echo 0)
        now_epoch=$(date '+%s')
        elapsed_secs=$(( now_epoch - start_epoch ))
        local h=$(( elapsed_secs / 3600 ))
        local m=$(( (elapsed_secs % 3600) / 60 ))
        uptime_str="${h}h ${m}m"
    else
        uptime_str="(unknown)"
    fi

    local total_images=0
    local set_count=0
    for dir in "$WALLPAPER_BASE"/*/; do
        [[ -d "$dir" ]] || continue
        (( set_count++ )) || true
        (( total_images += $(count_images "$dir") )) || true
    done

    local paused_label=""
    (( PAUSED == 1 )) && paused_label=" (paused)"

    echo ""
    echo "  Daemon uptime    : $uptime_str"
    echo "  Total switches   : $total_switches"
    echo "  Active sets      : $set_count"
    echo "  Total images     : $total_images"
    echo "  Active set       : $ACTIVE_SET${paused_label}"
    echo "  Timer            : $(( ACTIVE_SECONDS / 60 ))m / ${ACTIVE_MINS}m"
    echo ""
}

# ── shrutz history ────────────────────────────────────────────
cmd_history() {
    local n="${1:-10}"
    [[ "$n" =~ ^[0-9]+$ ]] || die "Usage: shrutz history [count]"

    echo ""
    printf '  %-22s  %-6s  %s\n' "TIMESTAMP" "POS" "WALLPAPER"
    printf '  %-22s  %-6s  %s\n' "──────────────────────" "──────" "─────────────────────"

    grep 'Switched →\|next →\|prev →' "$LOG_FILE" 2>/dev/null | tail -n "$n" | \
    while IFS= read -r line; do
        local ts img pos
        ts=$(echo "$line" | grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
        pos=$(echo "$line" | grep -oE '\[[0-9]+/[0-9]+\]' | tr -d '[]')
        img=$(echo "$line" | grep -oE '\] [^ ]+\.(jpg|jpeg|png|heic|webp)' | sed 's/^\] //')
        printf '  %-22s  %-6s  %s\n' "$ts" "$pos" "$img"
    done

    echo ""
}

# ── shrutz import ──────────────────────────────────────────────
cmd_import() {
    local src="" target_set=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --set)
                shift
                target_set="${1:-}"
                [[ -z "$target_set" ]] && die "--set requires a set name"
                ;;
            *)
                src="$1"
                ;;
        esac
        shift
    done

    [[ -z "$src" ]] && die "Usage: shrutz import <path> [--set <name>]"

    load_state
    [[ -z "$target_set" ]] && target_set="$ACTIVE_SET"

    local dir="$WALLPAPER_BASE/$target_set"
    [[ -d "$dir" ]] || die "set '$target_set' does not exist"

    echo "shrutz: importing into set '$target_set'..."
    _import_into "$src" "$dir"
    refresh_init_count "$dir"
    echo "shrutz: done — $(count_images "$dir") total images in '$target_set'"
}

# Internal: copy supported images from src (file or dir) into dest dir.
_import_into() {
    local src="$1" dest="$2"
    local added=0 skipped=0

    if [[ -f "$src" ]]; then
        _import_file "$src" "$dest" added skipped
    elif [[ -d "$src" ]]; then
        while IFS= read -r -d '' f; do
            _import_file "$f" "$dest" added skipped
        done < <(find "$src" -maxdepth 1 \
            \( -iname "*.jpg"  -o -iname "*.jpeg" \
            -o -iname "*.png"  -o -iname "*.heic" \
            -o -iname "*.webp" \) \
            -print0)
    else
        die "source '$src' is not a file or directory"
    fi

    echo "shrutz: $added added, $skipped skipped (duplicate filename)"
}

_import_file() {
    local src="$1" dest="$2"
    local -n _added=$3 _skipped=$4
    local fname
    fname=$(basename "$src")

    if [[ -f "$dest/$fname" ]]; then
        (( _skipped++ )) || true
    else
        cp "$src" "$dest/$fname"
        (( _added++ )) || true
    fi
}

# ── shrutz dash ───────────────────────────────────────────────
cmd_dash() {
    # Requires a terminal. Exit cleanly on q or Ctrl-C.
    command -v tput &>/dev/null || die "tput not available — dash requires a terminal"

    local DASH_REFRESH=5
    local hide_cursor show_cursor clear_screen
    hide_cursor=$(tput civis 2>/dev/null || true)
    show_cursor=$(tput cnorm 2>/dev/null || true)
    clear_screen=$(tput clear 2>/dev/null || true)

    # Restore cursor on exit
    trap "printf '%s' \"$show_cursor\"; tput rmcup 2>/dev/null; exit 0" INT TERM EXIT

    tput smcup 2>/dev/null || true
    printf '%s' "$hide_cursor"

    while true; do
        load_state

        local wallpaper_dir="$WALLPAPER_BASE/$ACTIVE_SET"
        local total; total=$(count_images "$wallpaper_dir")
        local shuffle_flag; shuffle_flag=$(init_field "$wallpaper_dir" "shuffle")

        # Resolve current wallpaper name
        local current_name="(unknown)"
        if (( total > 0 )); then
            local files=()
            while IFS= read -r -d '' f; do
                files+=("$f")
            done < <(find "$wallpaper_dir" -maxdepth 1 \
                \( -iname "*.jpg" -o -iname "*.jpeg" \
                -o -iname "*.png" -o -iname "*.heic" \
                -o -iname "*.webp" \) \
                -print0 | sort -z)
            if (( CURRENT_INDEX < ${#files[@]} )); then
                if [[ -n "$PLAY_ORDER" && "$shuffle_flag" == "true" ]]; then
                    local order=($PLAY_ORDER)
                    current_name=$(basename "${files[${order[$CURRENT_INDEX]}]}")
                else
                    current_name=$(basename "${files[$CURRENT_INDEX]}")
                fi
            fi
        fi

        # Timer progress bar (30 chars wide)
        local filled=0 bar="" pct=0
        if (( ACTIVE_SECS_NEEDED > 0 )); then
            pct=$(( ACTIVE_SECONDS * 100 / ACTIVE_SECS_NEEDED ))
            filled=$(( ACTIVE_SECONDS * 30 / ACTIVE_SECS_NEEDED ))
        fi
        (( filled > 30 )) && filled=30
        local i
        for (( i=0; i<filled; i++ ));    do bar+="█"; done
        for (( i=filled; i<30; i++ )); do bar+="░"; done

        local mins_done=$(( ACTIVE_SECONDS / 60 ))
        local mins_left=$(( (ACTIVE_SECS_NEEDED - ACTIVE_SECONDS) / 60 ))

        # Daemon uptime
        local uptime_str="(unknown)"
        local daemon_start
        daemon_start=$(grep 'shrutz started' "$LOG_FILE" 2>/dev/null | tail -1 | \
            grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
        if [[ -n "$daemon_start" ]]; then
            local start_epoch now_epoch elapsed
            start_epoch=$(date -j -f '%Y-%m-%d %H:%M:%S' "$daemon_start" '+%s' 2>/dev/null || echo 0)
            now_epoch=$(date '+%s')
            elapsed=$(( now_epoch - start_epoch ))
            uptime_str="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m"
        fi

        # Status tags
        local status_tags=""
        (( PAUSED == 1 )) && status_tags=" [PAUSED]"
        [[ "$shuffle_flag" == "true" ]] && status_tags+=" [SHUFFLE]"

        # Last 5 history entries
        local history_lines
        history_lines=$(grep 'Switched →\|next →\|prev →' "$LOG_FILE" 2>/dev/null | tail -5)

        # Total switches
        local total_switches
        total_switches=$(grep -c 'Switched →' "$LOG_FILE" 2>/dev/null || echo 0)

        # Draw
        printf '%s' "$clear_screen"
        printf '\n'
        printf '  ┌─────────────────────────────────────────────┐\n'
        printf '  │  shrutz dash                  %s │\n' "$(date '+%H:%M:%S')              " | cut -c1-49
        printf '  ├─────────────────────────────────────────────┤\n'
        printf '  │  %-43s│\n' ""
        printf '  │  Wallpaper : %-31s│\n' "$current_name"
        printf '  │  Set       : %-31s│\n' "$ACTIVE_SET${status_tags}"
        printf '  │  Position  : %-31s│\n' "$(( CURRENT_INDEX + 1 )) of $total"
        printf '  │  %-43s│\n' ""
        printf '  │  Timer     : [%s] %d%%%-14s│\n' "$bar" "$pct" ""
        printf '  │  Active    : %dm done / %dm to next%-9s│\n' "$mins_done" "$mins_left" ""
        printf '  │  Uptime    : %-31s│\n' "$uptime_str"
        printf '  │  Switches  : %-31s│\n' "$total_switches total"
        printf '  │  %-43s│\n' ""
        printf '  ├─────────────────────────────────────────────┤\n'
        printf '  │  Recent history                             │\n'
        printf '  │  %-43s│\n' ""
        if [[ -z "$history_lines" ]]; then
            printf '  │  %-43s│\n' "(no switches yet)"
        else
            while IFS= read -r line; do
                local ts img pos
                ts=$(echo "$line" | grep -oE '\[[0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
                pos=$(echo "$line" | grep -oE '\[[0-9]+/[0-9]+\]' | tr -d '[]')
                img=$(echo "$line" | grep -oE '[^ /]+\.(jpg|jpeg|png|heic|webp)')
                local entry="$ts  $pos  $img"
                printf '  │  %-43s│\n' "${entry:0:43}"
            done <<< "$history_lines"
        fi
        printf '  │  %-43s│\n' ""
        printf '  └─────────────────────────────────────────────┘\n'
        printf '\n  Press q to exit\n'

        # Non-blocking read for q
        local key=""
        IFS= read -r -s -n1 -t "$DASH_REFRESH" key 2>/dev/null || true
        [[ "$key" == "q" || "$key" == "Q" ]] && break
    done

    printf '%s' "$show_cursor"
    tput rmcup 2>/dev/null || true
}

# ── shrutz export ─────────────────────────────────────────────
cmd_export() {
    local name="${1:-}" dest="${2:-$HOME/Desktop}"
    [[ -z "$name" ]] && die "Usage: shrutz export <set> [destination]"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"
    [[ -d "$dest" ]] || die "destination '$dest' does not exist"

    local outfile="$dest/${name}.zip"
    echo "shrutz: exporting set '$name' to $outfile..."

    # zip the set directory; -j junks the paths so zip contains flat files
    # but we want to preserve the __init__ alongside images, so use -r with subdir
    (cd "$WALLPAPER_BASE" && zip -r "$outfile" "$name/" -x "*.DS_Store") || \
        die "zip failed — is zip installed?"

    local size
    size=$(du -sh "$outfile" | cut -f1)
    echo "shrutz: exported $size → $outfile"
}

# ── shrutz update ─────────────────────────────────────────────
cmd_update() {
    load_state

    [[ -z "$SHRUTZ_REPO" ]] && die "repo path unknown — reinstall shrutz to register SHRUTZ_REPO"
    [[ -d "$SHRUTZ_REPO/.git" ]] || die "SHRUTZ_REPO '$SHRUTZ_REPO' is not a git repository"

    echo "shrutz: pulling latest from $SHRUTZ_REPO..."
    git -C "$SHRUTZ_REPO" pull || die "git pull failed"

    echo "shrutz: running installer..."
    bash "$SHRUTZ_REPO/install.sh"

    # Installer restarts the daemon; preserve SHRUTZ_REPO in state
    # (install.sh will re-seed it, but belt-and-suspenders)
    echo "shrutz: update complete"
}

# ══════════════════════════════════════════════════════════════════
# ENTRY POINT
# ══════════════════════════════════════════════════════════════════

# When launchd starts shrutz it passes no arguments — run the daemon.
# When called by the user, dispatch to the right command.

case "${1:-daemon}" in
    daemon)       run_daemon ;;
    status)       cmd_status ;;
    log)          cmd_log ;;
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    sets)         cmd_sets ;;
    set)          shift; cmd_set "$@" ;;
    switch)       shift; cmd_switch "$@" ;;
    import)       shift; cmd_import "$@" ;;
    next)         cmd_next ;;
    prev)         cmd_prev ;;
    pause)        cmd_pause ;;
    resume)       cmd_resume ;;
    now)          cmd_now ;;
    config)       shift; cmd_config "$@" ;;
    stats)        cmd_stats ;;
    history)      shift; cmd_history "$@" ;;
    dash)         cmd_dash ;;
    export)       shift; cmd_export "$@" ;;
    update)       cmd_update ;;
    -h|--help|help)
        echo "Usage: shrutz <command> [args]"
        echo ""
        echo "  Daemon"
        echo "  ──────────────────────────────────────────────────"
        echo "  status                    show daemon status"
        echo "  log                       stream the live activity log"
        echo "  start                     load and start the daemon"
        echo "  stop                      unload and stop the daemon"
        echo "  update                    pull latest version and reinstall"
        echo ""
        echo "  Playback"
        echo "  ──────────────────────────────────────────────────"
        echo "  now                       current wallpaper + timer state"
        echo "  next                      skip to next wallpaper"
        echo "  prev                      go to previous wallpaper"
        echo "  pause                     freeze the active timer"
        echo "  resume                    unfreeze the active timer"
        echo "  dash                      live terminal dashboard"
        echo ""
        echo "  Sets"
        echo "  ──────────────────────────────────────────────────"
        echo "  sets                      list all wallpaper sets"
        echo "  set create <n> [src]      create a new set"
        echo "  set delete <n>            delete a set (cannot delete active)"
        echo "  set rename <old> <new>    rename a set"
        echo "  set info <n>              show set details and progress"
        echo "  set shuffle <n> <on|off>  enable/disable shuffle for a set"
        echo "  switch <set>              switch active wallpaper set"
        echo "  import <path>             import images into active set"
        echo "    --set <name>            import into a specific set instead"
        echo "  export <set> [dest]       zip a set for backup/sharing"
        echo ""
        echo "  Info"
        echo "  ──────────────────────────────────────────────────"
        echo "  stats                     daemon uptime, switch count, totals"
        echo "  history [n]               last n wallpaper switches (default 10)"
        echo "  config                    show tunables"
        echo "  config <key> <val>        set a tunable and restart daemon"
        echo "                            keys: ACTIVE_MINS IDLE_THRESHOLD CHECK_EVERY"
        echo ""
        ;;
    *)
        die "unknown command '$1' — run 'shrutz help' for usage"
        ;;
esac
