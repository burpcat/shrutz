#!/usr/bin/env bash
# ┌─────────────────────────────────────────────────────────────┐
# │  shrutz — active-time wallpaper rotator                     │
# │                                                             │
# │  Script  : ~/.local/bin/shrutz                             │
# │  Sets    : ~/.local/lib/shrutz/wallpapers/<set>/           │
# │  State   : ~/.local/lib/shrutz/state                       │
# │  Log     : ~/.local/lib/shrutz/shrutz.log                  │
# │  Agent   : ~/.local/etc/launchd/local.shrutz.plist         │
# │            (symlinked → ~/Library/LaunchAgents/)           │
# └─────────────────────────────────────────────────────────────┘

# ── Paths ──────────────────────────────────────────────────────
SHRUTZ_LIB="$HOME/.local/lib/shrutz"
WALLPAPER_BASE="$SHRUTZ_LIB/wallpapers"
STATE_FILE="$SHRUTZ_LIB/state"
LOG_FILE="$SHRUTZ_LIB/shrutz.log"
WALLPAPER_STORE="$HOME/Library/Application Support/com.apple.wallpaper/Store/Index.plist"
SHRUTZ_BIN="$HOME/.local/bin/shrutz"
LAUNCHAGENT_PLIST="$HOME/Library/LaunchAgents/local.shrutz.plist"
LAUNCHD_LABEL="local.shrutz"
WEATHER_MAP_FILE="$SHRUTZ_LIB/weather_map"

# ── Tunables ───────────────────────────────────────────────────
ACTIVE_MINS=30        # minutes of real use before switching
IDLE_THRESHOLD=60     # seconds without input → considered away
CHECK_EVERY=30        # how often the loop wakes up (seconds)
WEATHER_POLL_MINS=20  # how often to poll the weather API (minutes)

# ── Derived ────────────────────────────────────────────────────
ACTIVE_SECS_NEEDED=$(( ACTIVE_MINS * 60 ))

# Canonical weather condition vocabulary — used to validate `weather map`.
WEATHER_CONDITIONS=(clear cloudy fog rain snow storm night)

# ── Gallery ────────────────────────────────────────────────────
# A separate section, not a tunable — kept out of cmd_config's key
# whitelist so it's never mistaken for something meant to be edited live.
GALLERY_MANIFEST_URL="https://raw.githubusercontent.com/burpcat/shrutz/master/gallery/manifest.json"

# ══════════════════════════════════════════════════════════════════
# SHARED UTILITIES
# ══════════════════════════════════════════════════════════════════

log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

die() {
    printf 'shrutz: %s\n' "$*" >&2
    exit 1
}

# Load state into globals. Safe to call multiple times.
load_state() {
    CURRENT_INDEX=0
    ACTIVE_SECONDS=0
    ACTIVE_SET="default"
    PAUSED=0
    PLAY_ORDER=""        # space-separated shuffle order; empty = sequential
    SHRUTZ_REPO=""       # path to the git repo, set by installer
    WEATHER_ENABLED=0
    WEATHER_LAT=""
    WEATHER_LON=""
    WEATHER_LOCATION_LABEL=""
    WEATHER_LAST_POLL=0
    WEATHER_LAST_SET=""
    WEATHER_LAST_CONDITION=""
    WEATHER_LAST_TEMP_F=""
    [[ -f "$STATE_FILE" ]] && source "$STATE_FILE"
}

save_state() {
    printf 'CURRENT_INDEX=%d\nACTIVE_SECONDS=%d\nACTIVE_SET=%s\nPAUSED=%d\nPLAY_ORDER=%s\nSHRUTZ_REPO=%s\n' \
        "$CURRENT_INDEX" "$ACTIVE_SECONDS" "$ACTIVE_SET" "$PAUSED" \
        "$PLAY_ORDER" "$SHRUTZ_REPO" > "$STATE_FILE"
    # WEATHER_LOCATION_LABEL and WEATHER_LAST_SET are free-form strings that
    # can contain spaces/commas — %q-quote them so `source` reloads them
    # correctly (unquoted multi-word values break the plain fields above too,
    # a pre-existing issue not fixed here; these two are new, so they don't
    # repeat it).
    printf 'WEATHER_ENABLED=%d\nWEATHER_LAT=%s\nWEATHER_LON=%s\nWEATHER_LOCATION_LABEL=%q\nWEATHER_LAST_POLL=%d\nWEATHER_LAST_SET=%q\nWEATHER_LAST_CONDITION=%s\nWEATHER_LAST_TEMP_F=%s\n' \
        "$WEATHER_ENABLED" "$WEATHER_LAT" "$WEATHER_LON" "$WEATHER_LOCATION_LABEL" \
        "$WEATHER_LAST_POLL" "$WEATHER_LAST_SET" "$WEATHER_LAST_CONDITION" "$WEATHER_LAST_TEMP_F" \
        >> "$STATE_FILE"
}

# Resolve the active wallpaper directory from state.
active_set_dir() {
    echo "$WALLPAPER_BASE/$ACTIVE_SET"
}

# Read the __init__ field by key from a set directory.
# Usage: init_field <set_dir> <key>
init_field() {
    local dir="$1" key="$2"
    local init="$dir/__init__"
    [[ -f "$init" ]] && grep "^${key}=" "$init" | cut -d= -f2- || echo ""
}

# Count images in a set directory (excludes __init__).
count_images() {
    local dir="$1"
    find "$dir" -maxdepth 1 \
        \( -iname "*.jpg" -o -iname "*.jpeg" \
        -o -iname "*.png" -o -iname "*.heic" \
        -o -iname "*.webp" \) 2>/dev/null | wc -l | tr -d ' '
}

# Check a set directory exists and is non-empty.
assert_set_exists() {
    local name="$1"
    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]]     || die "set '$name' does not exist"
    (( $(count_images "$dir") > 0 )) || die "set '$name' has no images"
}

# Write (or overwrite) the __init__ metadata file for a set.
write_init() {
    local dir="$1" name="$2"
    local count
    count=$(count_images "$dir")
    cat > "$dir/__init__" << EOF
name=$name
created=$(date '+%Y-%m-%d %H:%M:%S')
images=$count
EOF
}

# Refresh the image count in an existing __init__ without touching other fields.
refresh_init_count() {
    local dir="$1"
    local count
    count=$(count_images "$dir")
    local init="$dir/__init__"
    if [[ -f "$init" ]]; then
        local tmp
        tmp=$(grep -v '^images=' "$init")
        printf '%s\nimages=%s\n' "$tmp" "$count" > "$init"
    fi
}

# Get the PID of the running daemon (launchd-managed shrutz process).
# launchd spawns: /usr/bin/env bash ~/.local/bin/shrutz  (no arguments)
# Anchored at end-of-string so this matches only that bare invocation —
# without the anchor it also matches any CLI subcommand currently running
# (e.g. "shrutz next" itself), since its argv contains the same path prefix.
daemon_pid() {
    pgrep -f "${SHRUTZ_BIN}\$" 2>/dev/null | head -1
}

# Signal the daemon to restart via launchd (SIGTERM → launchd restarts it).
restart_daemon() {
    local pid
    pid=$(daemon_pid)
    if [[ -n "$pid" ]]; then
        kill "$pid" 2>/dev/null || true
    fi
    return 0
}

# http_get <url> [timeout_seconds]
#
# Generic HTTP(S) GET — the only place shrutz touches the network. Not
# weather-specific; the gallery feature reuses this exact function for
# downloading zips (with a longer timeout, redirected to a file).
#
# Stdout: the raw response body on success. Binary-safe ONLY if redirected
# to a file (`http_get "$url" 30 > out.zip`) — capturing via `$()` strips
# trailing newlines and can't hold embedded NULs, which is fine for
# JSON/text but not for an arbitrary binary download.
#
# Exit code: 0 on an HTTP 2xx response, 1 on any failure (DNS/connect
# error, timeout, non-2xx status).
#
# Test override: if $SHRUTZ_HTTP_GET_STUB is set to an executable path,
# that's called instead of the network: "$SHRUTZ_HTTP_GET_STUB" "$url" "$timeout".
http_get() {
    local url="$1" timeout="${2:-10}"

    if [[ -n "${SHRUTZ_HTTP_GET_STUB:-}" ]]; then
        "$SHRUTZ_HTTP_GET_STUB" "$url" "$timeout"
        return $?
    fi

    HTTP_GET_URL="$url" HTTP_GET_TIMEOUT="$timeout" python3 << 'PYEOF'
import os, sys, urllib.request

url = os.environ['HTTP_GET_URL']
timeout = float(os.environ['HTTP_GET_TIMEOUT'])
try:
    req = urllib.request.Request(url, headers={'User-Agent': 'shrutz/1'})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        sys.stdout.buffer.write(resp.read())
except Exception as e:
    print(f"http_get: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

# ── Weather condition → set mapping (~/.local/lib/shrutz/weather_map) ──
# Flat "condition=set-name" file, one mapping per line — the same
# read/replace-one-key idiom already used on __init__ (grep to read,
# grep -v + re-append to replace).
weather_map_get() {
    local condition="$1"
    [[ -f "$WEATHER_MAP_FILE" ]] && grep "^${condition}=" "$WEATHER_MAP_FILE" | cut -d= -f2- || echo ""
}

weather_map_set() {
    local condition="$1" set_name="$2"
    touch "$WEATHER_MAP_FILE"
    if grep -q "^${condition}=" "$WEATHER_MAP_FILE"; then
        local tmp; tmp=$(grep -v "^${condition}=" "$WEATHER_MAP_FILE")
        printf '%s\n%s=%s\n' "$tmp" "$condition" "$set_name" > "$WEATHER_MAP_FILE"
    else
        printf '%s=%s\n' "$condition" "$set_name" >> "$WEATHER_MAP_FILE"
    fi
}

weather_map_remove() {
    local condition="$1"
    [[ -f "$WEATHER_MAP_FILE" ]] || return 0
    local tmp; tmp=$(grep -v "^${condition}=" "$WEATHER_MAP_FILE")
    printf '%s\n' "$tmp" > "$WEATHER_MAP_FILE"
}

weather_map_list() {
    [[ -f "$WEATHER_MAP_FILE" ]] && cat "$WEATHER_MAP_FILE"
}

# ══════════════════════════════════════════════════════════════════
# DAEMON INTERNALS
# ══════════════════════════════════════════════════════════════════

idle_seconds() {
    ioreg -c IOHIDSystem \
        | awk '/HIDIdleTime/ { print int($NF / 1000000000); exit }'
}

current_wallpaper() {
    osascript -e \
        'tell application "System Events" to get picture of desktop 1' \
        2>/dev/null | tr -d '\n'
}

apply_to_current_space() {
    local path="$1"
    osascript -e \
        "tell application \"System Events\"
            tell every desktop
                set picture to \"$path\"
            end tell
        end tell" 2>/dev/null
}

write_index_plist() {
    local path="$1"
    local store="$WALLPAPER_STORE"

    WP_PATH="$path" WP_STORE="$store" python3 << 'PYEOF'
import plistlib, datetime, os, sys

path  = os.environ['WP_PATH']
store = os.environ['WP_STORE']

config = plistlib.dumps(
    {'type': 'imageFile', 'url': {'relative': f'file://{path}'}},
    fmt=plistlib.FMT_BINARY
)
now = datetime.datetime.now()

def patch_desktop(desktop):
    content = desktop.get('Content', {})
    for choice in content.get('Choices', []):
        if choice.get('Provider') == 'com.apple.wallpaper.choice.image':
            choice['Configuration'] = config
            choice['Files'] = []
    desktop['LastSet'] = now

def patch_space(space):
    default = space.get('Default', {})
    if 'Desktop' in default:
        patch_desktop(default['Desktop'])
    for disp in space.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

try:
    with open(store, 'rb') as f:
        d = plistlib.load(f)

    if 'Desktop' in d.get('SystemDefault', {}):
        patch_desktop(d['SystemDefault']['Desktop'])

    for space in d.get('Spaces', {}).values():
        patch_space(space)

    for disp in d.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

    with open(store, 'wb') as f:
        plistlib.dump(d, f, fmt=plistlib.FMT_BINARY)

    print('ok')
except Exception as e:
    print(f'error: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
}

apply_all_spaces() {
    local path="$1"

    if [[ ! -f "$WALLPAPER_STORE" ]]; then
        apply_to_current_space "$path"
        log "Wallpaper store not found — applied to current space only (poll will correct others)"
        return
    fi

    if write_index_plist "$path"; then
        launchctl kickstart -k "gui/$(id -u)/com.apple.wallpaper.agent" 2>/dev/null || \
            killall WallpaperAgent 2>/dev/null || true
        sleep 1
        apply_to_current_space "$path"
        log "Applied to all spaces via Index.plist + agent reload"
    else
        apply_to_current_space "$path"
        log "Index.plist write failed — applied to current space only (poll will correct others)"
    fi
}

# ══════════════════════════════════════════════════════════════════
# WEATHER
# ══════════════════════════════════════════════════════════════════

# weather_bucket <wmo_code> [is_day]
#
# Maps an Open-Meteo weather_code to one of the WEATHER_CONDITIONS buckets.
# Returns "" for unrecognised codes (safe no-op upstream). The night
# override only applies to clear/cloudy — severe weather (rain/snow/storm/
# fog) stays as-is regardless of time of day, since a storm is more
# salient than day/night and users are unlikely to want it silently
# remapped to a generic starry-night set.
weather_bucket() {
    local code="$1" is_day="${2:-1}" bucket
    case "$code" in
        0)                                      bucket="clear"  ;;
        1|2|3)                                   bucket="cloudy" ;;
        45|48)                                   bucket="fog"    ;;
        51|53|55|56|57|61|63|65|66|67|80|81|82)  bucket="rain"   ;;
        71|73|75|77|85|86)                       bucket="snow"   ;;
        95|96|99)                                bucket="storm"  ;;
        *)                                        bucket=""      ;;
    esac
    if [[ "$is_day" == "0" ]] && [[ "$bucket" == "clear" || "$bucket" == "cloudy" ]]; then
        bucket="night"
    fi
    echo "$bucket"
}

# Fetch current weather for a lat/lon. Prints "CODE=<n>\nISDAY=<0|1>\nTEMPF=<n>"
# on success; returns 1 on any fetch/parse failure.
_weather_fetch() {
    local lat="$1" lon="$2"
    local url="https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=weather_code,is_day,temperature_2m&temperature_unit=fahrenheit"
    local body; body=$(http_get "$url") || return 1
    WEATHER_JSON="$body" python3 << 'PYEOF'
import json, os, sys
try:
    data = json.loads(os.environ['WEATHER_JSON'])
    current = data['current']
    print(f"CODE={int(current['weather_code'])}")
    print(f"ISDAY={int(current['is_day'])}")
    print(f"TEMPF={current['temperature_2m']}")
except Exception as e:
    print(f"error: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

_urlencode() {
    python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))' "$1"
}

# Resolve a city name to coordinates. Prints "LAT=<f>\nLON=<f>\nLABEL=<name>"
# on success; returns 1 if nothing matched or the request failed.
_weather_geocode() {
    local query="$1"
    local url="https://geocoding-api.open-meteo.com/v1/search?name=$(_urlencode "$query")&count=1&language=en&format=json"
    local body; body=$(http_get "$url") || return 1
    WEATHER_JSON="$body" python3 << 'PYEOF'
import json, os, sys
try:
    data = json.loads(os.environ['WEATHER_JSON'])
    results = data.get('results') or []
    if not results:
        print("error: no match", file=sys.stderr)
        sys.exit(1)
    r = results[0]
    label = ', '.join(p for p in (r.get('name'), r.get('admin1'), r.get('country')) if p)
    print(f"LAT={r['latitude']}")
    print(f"LON={r['longitude']}")
    print(f"LABEL={label}")
except Exception as e:
    print(f"error: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

# _weather_decide <lat> <lon>
#
# Prints "BUCKET=...\nTARGET=...\nTEMPF=..." — BUCKET/TARGET may be empty,
# that's a legitimate "no-op" outcome, not a failure. Returns 1 only on
# fetch/parse failure (network down, malformed response, etc).
_weather_decide() {
    local lat="$1" lon="$2" resp code is_day tempf bucket target
    resp=$(_weather_fetch "$lat" "$lon") || return 1
    code=$(echo "$resp"   | grep '^CODE='  | cut -d= -f2)
    is_day=$(echo "$resp" | grep '^ISDAY=' | cut -d= -f2)
    tempf=$(echo "$resp"  | grep '^TEMPF=' | cut -d= -f2)
    [[ -z "$code" ]] && return 1
    bucket=$(weather_bucket "$code" "$is_day")
    target=""
    [[ -n "$bucket" ]] && target=$(weather_map_get "$bucket")
    printf 'BUCKET=%s\nTARGET=%s\nTEMPF=%s\n' "$bucket" "$target" "$tempf"
}

# ══════════════════════════════════════════════════════════════════
# DAEMON — main loop
# ══════════════════════════════════════════════════════════════════

# _activate_set <name> [mode]
#
# Rebuild WALLPAPERS/TOTAL/shuffle state for wallpaper set <name> and apply
# the resulting wallpaper — the one shared "switch to a set, in-process"
# primitive. Used at daemon startup (mode=resume: keep CURRENT_INDEX/
# PLAY_ORDER if still valid — the same resume/regenerate logic the
# original startup code always ran) and by the weather auto-switch path
# (mode=switch, the default: always start at image 0, like a manual
# `shrutz switch`). Deliberately does NOT call restart_daemon() — unlike
# the CLI's cmd_switch, this runs inside the daemon's own process, so
# there's nothing to restart.
#
# Returns 1 (touches nothing) if <name>'s directory is missing or empty —
# callers decide what that means (fatal at daemon startup; "skip this
# poll, keep the current set" for weather).
_activate_set() {
    local name="$1" mode="${2:-switch}"
    local dir="$WALLPAPER_BASE/$name"

    local new_wallpapers=()
    while IFS= read -r -d '' f; do
        new_wallpapers+=("$f")
    done < <(find "$dir" -maxdepth 1 \
        \( -iname "*.jpg"  -o -iname "*.jpeg" \
        -o -iname "*.png"  -o -iname "*.heic" \
        -o -iname "*.webp" \) \
        -print0 2>/dev/null | sort -z)

    local new_total=${#new_wallpapers[@]}
    (( new_total == 0 )) && return 1

    ACTIVE_SET="$name"
    WALLPAPER_DIR="$dir"
    WALLPAPERS=("${new_wallpapers[@]}")
    TOTAL=$new_total

    SHUFFLE_MODE=0
    local set_shuffle
    set_shuffle=$(init_field "$WALLPAPER_DIR" "shuffle")
    [[ "$set_shuffle" == "true" ]] && SHUFFLE_MODE=1

    if [[ "$mode" == "resume" ]]; then
        (( CURRENT_INDEX >= TOTAL )) && CURRENT_INDEX=0
        local order_count=0
        [[ -n "$PLAY_ORDER" ]] && order_count=$(echo "$PLAY_ORDER" | wc -w | tr -d ' ')
        if (( SHUFFLE_MODE == 1 )) && { [[ -z "$PLAY_ORDER" ]] || (( order_count != TOTAL )); }; then
            _build_play_order
            CURRENT_INDEX=0
        fi
    else
        CURRENT_INDEX=0
        PLAY_ORDER=""
        (( SHUFFLE_MODE == 1 )) && _build_play_order
    fi

    local wp; wp=$(_resolve_wallpaper)
    apply_all_spaces "$wp"
    return 0
}

# _weather_maybe_check — called once per daemon tick (~every CHECK_EVERY
# seconds), independent of idle/active-time tracking. Cadence is its own
# persisted WEATHER_LAST_POLL vs wall-clock comparison. Never exits/dies —
# every failure path just logs and returns, the daemon must never crash
# over a network hiccup.
_weather_maybe_check() {
    (( PAUSED == 1 )) && return 0             # pause means "freeze all auto-rotation"
    (( WEATHER_ENABLED == 1 )) || return 0
    [[ -n "$WEATHER_LAT" && -n "$WEATHER_LON" ]] || return 0

    local now due_at
    now=$(date +%s)
    due_at=$(( WEATHER_LAST_POLL + WEATHER_POLL_MINS * 60 ))
    (( now < due_at )) && return 0
    WEATHER_LAST_POLL=$now   # mark attempted regardless of outcome — avoids retry storms on outage

    local decision
    if ! decision=$(_weather_decide "$WEATHER_LAT" "$WEATHER_LON"); then
        log "weather: fetch failed — will retry in ~${WEATHER_POLL_MINS}m"
        return 0
    fi

    local bucket target tempf
    bucket=$(echo "$decision" | grep '^BUCKET=' | cut -d= -f2-)
    target=$(echo "$decision" | grep '^TARGET='  | cut -d= -f2-)
    tempf=$(echo "$decision"  | grep '^TEMPF='   | cut -d= -f2-)
    WEATHER_LAST_CONDITION="$bucket"
    [[ -n "$tempf" ]] && WEATHER_LAST_TEMP_F="$tempf"

    if [[ -z "$bucket" ]]; then
        log "weather: unrecognised condition code — skipping"
        return 0
    fi
    if [[ -z "$target" ]]; then
        log "weather: '$bucket' has no mapped set — skipping"
        return 0
    fi
    # Anti-thrash: only act when the weather-mapped target differs from
    # the set weather itself last chose — not from whatever is currently
    # active. This lets a manual `shrutz switch` to something unrelated
    # stand indefinitely as long as the underlying condition hasn't
    # changed (next poll's target still equals WEATHER_LAST_SET, a
    # no-op); once the condition genuinely changes, weather reasserts
    # control. cmd_switch deliberately never touches WEATHER_LAST_SET.
    if [[ "$target" == "$WEATHER_LAST_SET" ]]; then
        return 0
    fi

    if [[ ! -d "$WALLPAPER_BASE/$target" ]] || (( $(count_images "$WALLPAPER_BASE/$target") == 0 )); then
        log "weather: mapped set '$target' for '$bucket' is missing or empty — skipping"
        return 0
    fi
    if [[ "$ACTIVE_SET" == "$target" ]]; then
        WEATHER_LAST_SET="$target"   # already there (e.g. user switched here manually) — adopt silently
        return 0
    fi

    if _activate_set "$target"; then
        WEATHER_LAST_SET="$target"
        log "weather: '$bucket' → switched to set '$target' ([$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$(_resolve_wallpaper)"))"
    else
        log "weather: mapped set '$target' failed to activate — skipping"
    fi
}

run_daemon() {
    load_state

    # Rebuild or validate PLAY_ORDER
    _build_play_order() {
        PLAY_ORDER=$(python3 -c "
import random, sys
n = int(sys.argv[1])
order = list(range(n))
random.shuffle(order)
print(' '.join(map(str, order)))
" "$TOTAL")
        log "shuffle: new play order generated for $TOTAL images"
    }

    # Resolve the actual wallpaper path from index (shuffle-aware)
    _resolve_wallpaper() {
        if (( SHUFFLE_MODE == 1 )); then
            local order=($PLAY_ORDER)
            echo "${WALLPAPERS[${order[$CURRENT_INDEX]}]}"
        else
            echo "${WALLPAPERS[$CURRENT_INDEX]}"
        fi
    }

    # Advance index; reshuffle when the shuffle set wraps around
    _advance_index() {
        (( CURRENT_INDEX = (CURRENT_INDEX + 1) % TOTAL ))
        if (( SHUFFLE_MODE == 1 )) && (( CURRENT_INDEX == 0 )); then
            _build_play_order
        fi
    }

    _retreat_index() {
        (( CURRENT_INDEX = (CURRENT_INDEX - 1 + TOTAL) % TOTAL ))
    }

    # Build WALLPAPERS/TOTAL/shuffle state for ACTIVE_SET, resuming
    # CURRENT_INDEX/PLAY_ORDER if still valid — the same logic that used
    # to be inlined here directly, now shared with the weather auto-switch
    # path via _activate_set() (defined above, near apply_all_spaces()).
    if ! _activate_set "$ACTIVE_SET" resume; then
        log "ERROR: no images found in $WALLPAPER_BASE/$ACTIVE_SET — exiting"
        exit 1
    fi

    # ── Signal handlers ────────────────────────────────────────
    trap '_sig_next' USR1
    trap '_sig_prev' USR2
    trap '_sig_pause_toggle' HUP

    _sig_next() {
        _advance_index
        local wp; wp=$(_resolve_wallpaper)
        # Fast path: apply to current space instantly via AppleScript.
        # The poll loop corrects remaining spaces within 30 seconds.
        apply_to_current_space "$wp"
        log "next → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp") (timer unchanged)"
        save_state
    }

    _sig_prev() {
        _retreat_index
        local wp; wp=$(_resolve_wallpaper)
        # Fast path: apply to current space instantly via AppleScript.
        # The poll loop corrects remaining spaces within 30 seconds.
        apply_to_current_space "$wp"
        log "prev → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp") (timer unchanged)"
        save_state
    }

    _sig_pause_toggle() {
        if (( PAUSED == 0 )); then
            PAUSED=1
            log "paused — active timer frozen at ${ACTIVE_SECONDS}s"
        else
            PAUSED=0
            log "resumed — active timer continuing from ${ACTIVE_SECONDS}s"
        fi
        save_state
    }

    local shuffle_label=""
    (( SHUFFLE_MODE == 1 )) && shuffle_label=" [shuffle]"
    log "shrutz started — set='$ACTIVE_SET'${shuffle_label} $TOTAL wallpapers, rotate every ${ACTIVE_MINS}m active use"
    [[ "$PAUSED" == "1" ]] && log "note: starting in paused state"
    log "Restored → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$(_resolve_wallpaper)")"

    while true; do
        # Backgrounded + waited (not a plain foreground `sleep`) so that
        # USR1/USR2/HUP traps fire immediately when next/prev/pause/resume
        # signal the daemon. Bash defers trap execution until a foreground
        # command finishes, but `wait` on a background job is interrupted
        # by a pending trap right away — otherwise next/prev could take up
        # to $CHECK_EVERY seconds to take effect.
        sleep "$CHECK_EVERY" &
        wait "$!"

        idle=$(idle_seconds)

        if (( idle < IDLE_THRESHOLD )) && (( PAUSED == 0 )); then
            (( ACTIVE_SECONDS += CHECK_EVERY ))

            if (( ACTIVE_SECONDS >= ACTIVE_SECS_NEEDED )); then
                _advance_index
                local wp; wp=$(_resolve_wallpaper)
                apply_all_spaces "$wp"
                ACTIVE_SECONDS=0
                log "Switched → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "$wp")"

            else
                local expected; expected=$(_resolve_wallpaper)
                local current; current=$(current_wallpaper)
                if [[ "$current" != "$expected" ]]; then
                    apply_to_current_space "$expected"
                    log "Mismatch on active space — reapplied: $(basename "$expected")"
                fi
            fi
        fi

        _weather_maybe_check

        save_state
    done
}

