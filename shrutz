# ── shrutz --version ───────────────────────────────────────────
# No version constant embedded in the script itself — that would need a
# build/sync step to keep in lockstep with the repo's VERSION file, which
# this single-file-script project has never needed. install.sh copies
# VERSION into $SHRUTZ_LIB alongside the man page; if it's missing (e.g.
# someone copied only the raw script), fall back to "unknown" rather
# than erroring.
cmd_version() {
    if [[ -f "$SHRUTZ_LIB/VERSION" ]]; then
        echo "shrutz $(cat "$SHRUTZ_LIB/VERSION")"
    else
        echo "shrutz unknown"
    fi
}

cmd_status() {
    if [[ "${1:-}" == "--json" ]]; then
        local out loaded="false" pid=0 last_exit=0
        if out=$(launchctl list "$LAUNCHD_LABEL" 2>/dev/null); then
            loaded="true"
            pid=$(echo "$out" | grep '"PID"' | grep -oE '[0-9]+' | head -1)
            last_exit=$(echo "$out" | grep '"LastExitStatus"' | grep -oE '\-?[0-9]+' | head -1)
            [[ -z "$pid" ]] && pid=0
            [[ -z "$last_exit" ]] && last_exit=0
