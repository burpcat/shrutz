# ENTRY POINT
# ══════════════════════════════════════════════════════════════════

# When launchd starts shrutz it passes no arguments — run the daemon.
# When called by the user, dispatch to the right command.

case "${1:-daemon}" in
    daemon)       run_daemon ;;
    status)       shift; cmd_status "$@" ;;
    log)          cmd_log ;;
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    sets)         shift; cmd_sets "$@" ;;
    set)          shift; cmd_set "$@" ;;
    switch)       shift; cmd_switch "$@" ;;
    import)       shift; cmd_import "$@" ;;
    next)         cmd_next ;;
    prev)         cmd_prev ;;
    pause)        cmd_pause ;;
    resume)       cmd_resume ;;
    now)          shift; cmd_now "$@" ;;
    config)       shift; cmd_config "$@" ;;
    weather)      shift; cmd_weather "$@" ;;
    stats)        shift; cmd_stats "$@" ;;
    history)      shift; cmd_history "$@" ;;
    dash)         cmd_dash ;;
    export)       shift; cmd_export "$@" ;;
    gallery)      shift; cmd_gallery "$@" ;;
    menubar)      shift; cmd_menubar "$@" ;;
    update)       cmd_update ;;
    dieanddontcomeback) shift; cmd_dieanddontcomeback "$@" ;;
    -v|--version) cmd_version ;;
    -h|--help|help)
        echo "Usage: shrutz <command> [args]"
        echo ""
        echo "  -v, --version             print the installed version"
        echo ""
        echo "  Daemon"
        echo "  ──────────────────────────────────────────────────"
        echo "  status                    show daemon status"
        echo "  log                       stream the live activity log"
        echo "  start                     load and start the daemon"
        echo "  stop                      unload and stop the daemon"
        echo "  update                    pull latest version and reinstall"
