# ENTRY POINT
# ══════════════════════════════════════════════════════════════════

# When launchd starts shrutz it passes no arguments — run the daemon.
# When called by the user, dispatch to the right command.

case "${1:-daemon}" in
    daemon)       run_daemon ;;
    status)       cmd_status ;;
    log)          cmd_log ;;
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    sets)         cmd_sets ;;
    set)          shift; cmd_set "$@" ;;
    switch)       shift; cmd_switch "$@" ;;
    import)       shift; cmd_import "$@" ;;
    next)         cmd_next ;;
    prev)         cmd_prev ;;
    pause)        cmd_pause ;;
    resume)       cmd_resume ;;
    now)          cmd_now ;;
    config)       shift; cmd_config "$@" ;;
    stats)        cmd_stats ;;
    history)      shift; cmd_history "$@" ;;
    -h|--help|help)
        echo "Usage: shrutz <command> [args]"
        echo ""
        echo "  Daemon"
        echo "  ──────────────────────────────────────────────────"
        echo "  status              show daemon status"
        echo "  log                 stream the live activity log"
        echo "  start               load and start the daemon"
        echo "  stop                unload and stop the daemon"
        echo ""
        echo "  Playback"
        echo "  ──────────────────────────────────────────────────"
        echo "  now                 current wallpaper + timer state"
        echo "  next                skip to next wallpaper"
        echo "  prev                go to previous wallpaper"
        echo "  pause               freeze the active timer"
        echo "  resume              unfreeze the active timer"
        echo ""
        echo "  Sets"
        echo "  ──────────────────────────────────────────────────"
        echo "  sets                list all wallpaper sets"
        echo "  set create <n>      create a new set (optional: <n> <src-path>)"
        echo "  set delete <n>      delete a set (cannot delete active)"
        echo "  set rename <o> <n>  rename a set"
        echo "  set info <n>        show set details and progress"
        echo "  switch <set>        switch active wallpaper set"
        echo "  import <path>       import images into active set"
        echo "    --set <name>      import into a specific set instead"
        echo ""
        echo "  Info"
        echo "  ──────────────────────────────────────────────────"
        echo "  stats               daemon uptime, switch count, totals"
        echo "  history [n]         last n wallpaper switches (default 10)"
        echo "  config              show tunables"
        echo "  config <key> <val>  set a tunable and restart daemon"
        echo "                      keys: ACTIVE_MINS IDLE_THRESHOLD CHECK_EVERY"
        echo ""
        ;;
    *)
        die "unknown command '$1' — run 'shrutz help' for usage"
        ;;
esac
