# ── shrutz sets ────────────────────────────────────────────────
cmd_sets() {
    load_state

    if [[ "${1:-}" == "--json" ]]; then
        local rows=""
        for dir in "$WALLPAPER_BASE"/*/; do
            [[ -d "$dir" ]] || continue
            local name images created shuffle active
            name=$(basename "$dir")
            images=$(count_images "$dir")
            created=$(init_field "$dir" "created")
            shuffle="false"
            [[ "$(init_field "$dir" "shuffle")" == "true" ]] && shuffle="true"
            active="false"
            [[ "$name" == "$ACTIVE_SET" ]] && active="true"
            rows+="${name}"$'\t'"${images}"$'\t'"${created}"$'\t'"${active}"$'\t'"${shuffle}"$'\n'
        done
        SETS_ROWS="$rows" python3 << 'PYEOF'
import json, os
out = []
for line in os.environ['SETS_ROWS'].splitlines():
    if not line:
        continue
    name, images, created, active, shuffle = line.split('\t')
    out.append({
        "name": name,
        "images": int(images),
        "created": created,
        "active": active == "true",
        "shuffle": shuffle == "true",
    })
print(json.dumps(out))
PYEOF
        return
    fi

    local found=0
    printf '\n  %-24s  %-8s  %-20s  %s\n' "NAME" "IMAGES" "CREATED" ""
    printf '  %-24s  %-8s  %-20s\n' "────────────────────────" "────────" "────────────────────"
    for dir in "$WALLPAPER_BASE"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        local images created marker
        images=$(count_images "$dir")
        created=$(init_field "$dir" "created")
        [[ "$name" == "$ACTIVE_SET" ]] && marker=" ◀ active" || marker=""
        printf '  %-24s  %-8s  %-20s  %s\n' "$name" "$images" "$created" "$marker"
        found=1
    done
    (( found == 0 )) && echo "  (no sets found — create one with: shrutz set create <name>)"
    echo ""
}

# ── shrutz set <subcommand> ────────────────────────────────────
cmd_set() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create)  cmd_set_create "$@" ;;
        delete)  cmd_set_delete "$@" ;;
        rename)  cmd_set_rename "$@" ;;
        info)    cmd_set_info   "$@" ;;
        shuffle) cmd_set_shuffle "$@" ;;
        *)
            echo "Usage: shrutz set <create|delete|rename|info|shuffle> [args]"
            exit 1
            ;;
    esac
}

cmd_set_create() {
    local name="${1:-}"
    local src="${2:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set create <name> [source-path]"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] && die "set '$name' already exists"

    mkdir -p "$dir"
    write_init "$dir" "$name"
    echo "shrutz: created set '$name'"

    if [[ -n "$src" ]]; then
        echo "shrutz: importing from '$src'..."
        _import_into "$src" "$dir"
        refresh_init_count "$dir"
        echo "shrutz: done — $(count_images "$dir") images in '$name'"
    fi
}

cmd_set_delete() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set delete <name>"

    load_state
    [[ "$name" == "$ACTIVE_SET" ]] && die "cannot delete the active set ('$name' is in use — switch first)"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    printf 'shrutz: delete set "%s" and all its images? [y/N] ' "$name"
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "shrutz: cancelled"; exit 0; }

    rm -rf "$dir"
    echo "shrutz: deleted set '$name'"
}

cmd_set_rename() {
    local old="${1:-}" new="${2:-}"
    [[ -z "$old" || -z "$new" ]] && die "Usage: shrutz set rename <old> <new>"

    local old_dir="$WALLPAPER_BASE/$old"
    local new_dir="$WALLPAPER_BASE/$new"
    [[ -d "$old_dir" ]] || die "set '$old' does not exist"
    [[ -d "$new_dir" ]] && die "set '$new' already exists"

    mv "$old_dir" "$new_dir"

    # Patch name field in __init__
    local init="$new_dir/__init__"
    if [[ -f "$init" ]]; then
        local tmp
        tmp=$(grep -v '^name=' "$init")
        printf '%s\nname=%s\n' "$tmp" "$new" > "$init"
    fi

    load_state
    if [[ "$ACTIVE_SET" == "$old" ]]; then
        ACTIVE_SET="$new"
        save_state
        echo "shrutz: renamed '$old' → '$new' (active set updated)"
        restart_daemon
    else
        echo "shrutz: renamed '$old' → '$new'"
    fi
}

cmd_set_info() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz set info <name>"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    load_state

    local images created disksize active_marker
    images=$(count_images "$dir")
    created=$(init_field "$dir" "created")
    disksize=$(du -sh "$dir" 2>/dev/null | cut -f1)
    [[ "$name" == "$ACTIVE_SET" ]] && active_marker=" (active)" || active_marker=""

    echo ""
    echo "  Set: $name$active_marker"
    echo "  Created:    $created"
    echo "  Images:     $images"
    echo "  Disk usage: $disksize"

    if [[ "$name" == "$ACTIVE_SET" ]]; then
        local mins_done mins_left
        mins_done=$(( ACTIVE_SECONDS / 60 ))
        mins_left=$(( (ACTIVE_SECS_NEEDED - ACTIVE_SECONDS) / 60 ))
        echo "  Progress:   ${mins_done}m active / ${ACTIVE_MINS}m needed (${mins_left}m remaining)"
        echo "  Position:   image $(( CURRENT_INDEX + 1 )) of $images"
    fi
    echo ""
}

cmd_set_shuffle() {
    local name="${1:-}" mode="${2:-}"
    [[ -z "$name" || -z "$mode" ]] && die "Usage: shrutz set shuffle <name> <on|off>"
    [[ "$mode" != "on" && "$mode" != "off" ]] && die "mode must be 'on' or 'off'"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"

    local init="$dir/__init__"
    local flag; [[ "$mode" == "on" ]] && flag="true" || flag="false"

    if [[ -f "$init" ]]; then
        if grep -q '^shuffle=' "$init"; then
            local tmp; tmp=$(grep -v '^shuffle=' "$init")
            printf '%s\nshuffle=%s\n' "$tmp" "$flag" > "$init"
        else
            printf 'shuffle=%s\n' "$flag" >> "$init"
        fi
    else
        printf 'name=%s\ncreated=%s\nimages=%s\nshuffle=%s\n' \
            "$name" "$(date '+%Y-%m-%d %H:%M:%S')" "$(count_images "$dir")" "$flag" > "$init"
    fi

    echo "shrutz: shuffle $mode for set '$name'"

    load_state
    if [[ "$ACTIVE_SET" == "$name" ]]; then
        # Clear stale play order so daemon regenerates on restart
        PLAY_ORDER=""
        save_state
        restart_daemon
        echo "shrutz: daemon restarted with shuffle $mode"
    fi
}

# ── shrutz switch ──────────────────────────────────────────────
cmd_switch() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shrutz switch <set>"

    assert_set_exists "$name"
    load_state

    if [[ "$ACTIVE_SET" == "$name" ]]; then
        echo "shrutz: '$name' is already the active set"
        exit 0
    fi

    # Preserve ACTIVE_SECONDS — the timer is never touched by switch
    ACTIVE_SET="$name"
    CURRENT_INDEX=0
    save_state

    restart_daemon
    echo "shrutz: switched to set '$name' (timer continues from ${ACTIVE_SECONDS}s)"
}

# ── shrutz next ───────────────────────────────────────────────
cmd_next() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    kill -USR1 "$pid"
    echo "shrutz: next wallpaper (timer unchanged)"
}

# ── shrutz prev ───────────────────────────────────────────────
cmd_prev() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    kill -USR2 "$pid"
    echo "shrutz: previous wallpaper (timer unchanged)"
}

# ── shrutz pause / resume ─────────────────────────────────────
cmd_pause() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    load_state
    (( PAUSED == 1 )) && { echo "shrutz: already paused — use 'shrutz resume'"; exit 0; }
    kill -HUP "$pid"
    echo "shrutz: paused"
}

cmd_resume() {
    local pid
    pid=$(daemon_pid)
    [[ -z "$pid" ]] && die "daemon is not running"
    load_state
    (( PAUSED == 0 )) && { echo "shrutz: not paused — use 'shrutz pause'"; exit 0; }
    kill -HUP "$pid"
    echo "shrutz: resumed"
}

# ── shrutz now ────────────────────────────────────────────────
cmd_now() {
    load_state

    local wallpaper_dir="$WALLPAPER_BASE/$ACTIVE_SET"
    local total
    total=$(count_images "$wallpaper_dir")

    local current_name="(unknown)" current_path=""
    if (( total > 0 )); then
        # Rebuild sorted list to resolve name from index
        local files=()
        while IFS= read -r -d '' f; do
            files+=("$f")
        done < <(find "$wallpaper_dir" -maxdepth 1 \
            \( -iname "*.jpg" -o -iname "*.jpeg" \
            -o -iname "*.png" -o -iname "*.heic" \
            -o -iname "*.webp" \) \
            -print0 | sort -z)
        if (( CURRENT_INDEX < ${#files[@]} )); then
            current_path="${files[$CURRENT_INDEX]}"
            current_name=$(basename "$current_path")
        fi
    fi

    local seconds_remaining=$(( ACTIVE_SECS_NEEDED - ACTIVE_SECONDS ))
    local shuffle="false"
    [[ "$(init_field "$wallpaper_dir" "shuffle")" == "true" ]] && shuffle="true"
    local paused="false"
    (( PAUSED == 1 )) && paused="true"

    if [[ "${1:-}" == "--json" ]]; then
        NJ_WP="$current_name" NJ_PATH="$current_path" NJ_SET="$ACTIVE_SET" \
        NJ_POS="$(( CURRENT_INDEX + 1 ))" NJ_TOTAL="$total" NJ_ACTIVE_SECS="$ACTIVE_SECONDS" \
        NJ_MINS_NEEDED="$ACTIVE_MINS" NJ_REMAINING="$seconds_remaining" \
        NJ_PAUSED="$paused" NJ_SHUFFLE="$shuffle" python3 << 'PYEOF'
import json, os
print(json.dumps({
    "wallpaper": os.environ['NJ_WP'],
    "wallpaper_path": os.environ['NJ_PATH'],
    "set": os.environ['NJ_SET'],
    "position": int(os.environ['NJ_POS']),
    "total": int(os.environ['NJ_TOTAL']),
    "active_seconds": int(os.environ['NJ_ACTIVE_SECS']),
    "active_minutes_needed": int(os.environ['NJ_MINS_NEEDED']),
    "seconds_remaining": int(os.environ['NJ_REMAINING']),
    "paused": os.environ['NJ_PAUSED'] == "true",
    "shuffle": os.environ['NJ_SHUFFLE'] == "true",
}))
PYEOF
        return
    fi

    local mins_done mins_left
    mins_done=$(( ACTIVE_SECONDS / 60 ))
    mins_left=$(( seconds_remaining / 60 ))
    local paused_label=""
    (( PAUSED == 1 )) && paused_label=" [PAUSED]"

    echo ""
    echo "  Wallpaper : $current_name"
    echo "  Set       : $ACTIVE_SET"
    echo "  Position  : $(( CURRENT_INDEX + 1 )) of $total"
    echo "  Timer     : ${mins_done}m active / ${ACTIVE_MINS}m needed (${mins_left}m to next)${paused_label}"
    echo ""
}

# ── shrutz config ─────────────────────────────────────────────
cmd_config() {
    local script="$SHRUTZ_BIN"
    local key="${1:-}" val="${2:-}"

    if [[ "$key" == "--json" ]]; then
        local active_mins idle_threshold check_every weather_poll_mins
        active_mins=$(grep -E '^ACTIVE_MINS=' "$script" | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
        idle_threshold=$(grep -E '^IDLE_THRESHOLD=' "$script" | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
        check_every=$(grep -E '^CHECK_EVERY=' "$script" | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
        weather_poll_mins=$(grep -E '^WEATHER_POLL_MINS=' "$script" | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
        CJ_MINS="$active_mins" CJ_IDLE="$idle_threshold" CJ_CHECK="$check_every" CJ_WEATHER="$weather_poll_mins" python3 << 'PYEOF'
import json, os
print(json.dumps({
    "active_mins": int(os.environ['CJ_MINS']),
    "idle_threshold": int(os.environ['CJ_IDLE']),
    "check_every": int(os.environ['CJ_CHECK']),
    "weather_poll_mins": int(os.environ['CJ_WEATHER']),
}))
PYEOF
        return
    fi

    if [[ -z "$key" ]]; then
        # Pretty-print current tunables
        echo ""
        echo "  Tunables (edit with: shrutz config <key> <value>)"
        echo ""
        grep -E '^(ACTIVE_MINS|IDLE_THRESHOLD|CHECK_EVERY|WEATHER_POLL_MINS)=' "$script" | \
        while IFS='=' read -r k v; do
            # Strip inline comment
            v="${v%%#*}"
            v="${v%"${v##*[![:space:]]}"}"  # rtrim
            case "$k" in
                ACTIVE_MINS)        printf '  %-20s = %s  (minutes active before switching)\n' "$k" "$v" ;;
                IDLE_THRESHOLD)     printf '  %-20s = %s  (seconds idle before pausing timer)\n' "$k" "$v" ;;
                CHECK_EVERY)        printf '  %-20s = %s  (poll interval in seconds)\n' "$k" "$v" ;;
                WEATHER_POLL_MINS)  printf '  %-20s = %s  (minutes between weather checks)\n' "$k" "$v" ;;
            esac
        done
        echo ""
        return
    fi

    # Validate key
    case "$key" in
        ACTIVE_MINS|IDLE_THRESHOLD|CHECK_EVERY|WEATHER_POLL_MINS) ;;
        *) die "unknown config key '$key' — valid keys: ACTIVE_MINS, IDLE_THRESHOLD, CHECK_EVERY, WEATHER_POLL_MINS" ;;
    esac

    [[ -z "$val" ]] && die "Usage: shrutz config <key> <value>"
    [[ "$val" =~ ^[0-9]+$ ]] || die "value must be a positive integer"

    # In-place sed edit on the script
    sed -i '' "s/^\(${key}=\)[0-9]*/\1${val}/" "$script"
    echo "shrutz: $key set to $val"

    # Restart daemon so it picks up new tunables
    restart_daemon
    echo "shrutz: daemon restarted"
}

# ── shrutz weather ─────────────────────────────────────────────
cmd_weather() {
    local subcmd="${1:-status}"
    (( $# > 0 )) && shift

    case "$subcmd" in
        status)   cmd_weather_status "$@" ;;
        --json)   cmd_weather_status --json ;;
        on)       cmd_weather_on ;;
        off)      cmd_weather_off ;;
        location) cmd_weather_location "$@" ;;
        map)      cmd_weather_map "$@" ;;
        unmap)    cmd_weather_unmap "$@" ;;
        check)    cmd_weather_check ;;
        *) die "Usage: shrutz weather <status|on|off|location|map|unmap|check> [args]" ;;
    esac
}

cmd_weather_status() {
    load_state

    if [[ "${1:-}" == "--json" ]]; then
        local enabled="false"
        (( WEATHER_ENABLED == 1 )) && enabled="true"
        local last_checked=""
        [[ "$WEATHER_LAST_POLL" != "0" ]] && \
            last_checked=$(date -r "$WEATHER_LAST_POLL" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "")

        WJ_ENABLED="$enabled" WJ_LOCATION="$WEATHER_LOCATION_LABEL" WJ_CONDITION="$WEATHER_LAST_CONDITION" \
        WJ_TEMPF="$WEATHER_LAST_TEMP_F" WJ_CHECKED="$last_checked" python3 << 'PYEOF'
import json, os

def as_bool(v): return v == "true"
def as_num(v):
    try:
        return float(v)
    except Exception:
        return None

enabled = as_bool(os.environ['WJ_ENABLED'])
print(json.dumps({
    "enabled": enabled,
    "location": os.environ['WJ_LOCATION'],
    "condition": os.environ['WJ_CONDITION'],
    "temperature_f": as_num(os.environ['WJ_TEMPF']),
    "auto_switch": enabled,
    "last_checked": os.environ['WJ_CHECKED'],
}))
PYEOF
        return
    fi

    echo ""
    if (( WEATHER_ENABLED == 1 )); then
        echo "  Auto-switching : on"
    else
        echo "  Auto-switching : off"
    fi
    if [[ -n "$WEATHER_LOCATION_LABEL" ]]; then
        echo "  Location       : $WEATHER_LOCATION_LABEL ($WEATHER_LAT, $WEATHER_LON)"
    else
        echo "  Location       : (not set — shrutz weather location <city|lat,lon>)"
    fi
    echo "  Poll interval  : ${WEATHER_POLL_MINS}m"
    if [[ -n "$WEATHER_LAST_CONDITION" ]]; then
        local temp_label=""
        [[ -n "$WEATHER_LAST_TEMP_F" ]] && temp_label=", ${WEATHER_LAST_TEMP_F}°F"
        echo "  Last condition : $WEATHER_LAST_CONDITION${temp_label}"
    else
        echo "  Last condition : (none yet)"
    fi
    [[ -n "$WEATHER_LAST_SET" ]] && echo "  Last weather set: $WEATHER_LAST_SET"
    echo ""
    echo "  Mappings"
    echo "  ──────────────────────────────────────────────────"
    if [[ -f "$WEATHER_MAP_FILE" && -s "$WEATHER_MAP_FILE" ]]; then
        while IFS='=' read -r cond setname; do
            [[ -z "$cond" ]] && continue
            printf '  %-10s → %s\n' "$cond" "$setname"
        done < "$WEATHER_MAP_FILE"
    else
        echo "  (none configured — shrutz weather map <condition> <set>)"
    fi
    echo ""
    echo "  Conditions: ${WEATHER_CONDITIONS[*]}"
    echo ""
}

cmd_weather_on() {
    load_state
    [[ -n "$WEATHER_LAT" && -n "$WEATHER_LON" ]] || die "no location set — run: shrutz weather location <city|lat,lon>"
    WEATHER_ENABLED=1
    save_state
    restart_daemon
    if [[ ! -f "$WEATHER_MAP_FILE" || ! -s "$WEATHER_MAP_FILE" ]]; then
        echo "shrutz: weather auto-switching on (no mappings configured yet — shrutz weather map <condition> <set>)"
    else
        echo "shrutz: weather auto-switching on"
    fi
}

cmd_weather_off() {
    load_state
    WEATHER_ENABLED=0
    save_state
    restart_daemon
    echo "shrutz: weather auto-switching off"
}

cmd_weather_location() {
    local raw="$*"
    [[ -z "$raw" ]] && die "Usage: shrutz weather location <city name> | <lat,lon>"
    load_state

    if [[ "$raw" =~ ^-?[0-9]+(\.[0-9]+)?,-?[0-9]+(\.[0-9]+)?$ ]]; then
        local lat="${raw%%,*}" lon="${raw##*,}"
        WLAT="$lat" WLON="$lon" python3 -c "
import os, sys
lat, lon = float(os.environ['WLAT']), float(os.environ['WLON'])
sys.exit(0 if (-90 <= lat <= 90 and -180 <= lon <= 180) else 1)
" || die "latitude must be -90..90 and longitude -180..180"
        WEATHER_LAT="$lat"
        WEATHER_LON="$lon"
        WEATHER_LOCATION_LABEL="custom ($lat, $lon)"
        save_state
        restart_daemon
        echo "shrutz: location set to $lat, $lon"
    else
        echo "shrutz: looking up '$raw'..."
        local result
        result=$(_weather_geocode "$raw") || die "could not resolve '$raw' — check spelling/network and try again"
        local lat lon label
        lat=$(echo "$result"   | grep '^LAT='   | cut -d= -f2-)
        lon=$(echo "$result"   | grep '^LON='   | cut -d= -f2-)
        label=$(echo "$result" | grep '^LABEL=' | cut -d= -f2-)
        [[ -z "$lat" || -z "$lon" ]] && die "geocoding returned no result for '$raw'"
        WEATHER_LAT="$lat"
        WEATHER_LON="$lon"
        WEATHER_LOCATION_LABEL="$label"
        save_state
        restart_daemon
        echo "shrutz: location set to '$label' ($lat, $lon)"
    fi
}

cmd_weather_map() {
    local condition="${1:-}" set_name="${2:-}"

    if [[ -z "$condition" && -z "$set_name" ]]; then
        if [[ -f "$WEATHER_MAP_FILE" && -s "$WEATHER_MAP_FILE" ]]; then
            echo ""
            echo "  Weather mappings"
            echo "  ──────────────────────────────────────────────────"
            while IFS='=' read -r cond setname; do
                [[ -z "$cond" ]] && continue
                printf '  %-10s → %s\n' "$cond" "$setname"
            done < "$WEATHER_MAP_FILE"
            echo ""
        else
            echo "shrutz: no weather mappings configured"
        fi
        echo "  Conditions: ${WEATHER_CONDITIONS[*]}"
        return
    fi

    [[ -z "$condition" || -z "$set_name" ]] && die "Usage: shrutz weather map <condition> <set>"

    local valid=0 c
    for c in "${WEATHER_CONDITIONS[@]}"; do [[ "$c" == "$condition" ]] && valid=1; done
    (( valid == 1 )) || die "unknown condition '$condition' — valid: ${WEATHER_CONDITIONS[*]}"

    assert_set_exists "$set_name"
    weather_map_set "$condition" "$set_name"
    echo "shrutz: weather condition '$condition' → set '$set_name'"
    restart_daemon
}

cmd_weather_unmap() {
    local condition="${1:-}"
    [[ -z "$condition" ]] && die "Usage: shrutz weather unmap <condition>"
    weather_map_remove "$condition"
    echo "shrutz: removed mapping for '$condition'"
    restart_daemon
}

cmd_weather_check() {
    load_state
    [[ "$WEATHER_ENABLED" == "1" ]] || die "weather auto-switching is off — enable with: shrutz weather on"
    [[ -n "$WEATHER_LAT" && -n "$WEATHER_LON" ]] || die "no location set — run: shrutz weather location <city|lat,lon>"
    echo "shrutz: checking weather for ${WEATHER_LOCATION_LABEL:-$WEATHER_LAT,$WEATHER_LON}..."

    local decision
    decision=$(_weather_decide "$WEATHER_LAT" "$WEATHER_LON") \
        || die "weather fetch failed — check your network connection and try again"

    local bucket target tempf
    bucket=$(echo "$decision" | grep '^BUCKET=' | cut -d= -f2-)
    target=$(echo "$decision" | grep '^TARGET=' | cut -d= -f2-)
    tempf=$(echo "$decision"  | grep '^TEMPF='  | cut -d= -f2-)
    WEATHER_LAST_CONDITION="$bucket"
    [[ -n "$tempf" ]] && WEATHER_LAST_TEMP_F="$tempf"
    WEATHER_LAST_POLL=$(date +%s)

    if [[ -z "$bucket" ]]; then
        save_state
        echo "shrutz: unrecognised weather condition — no mapping to check"
        return
    fi
    echo "shrutz: current condition: $bucket"

    if [[ -z "$target" ]]; then
        save_state
        echo "shrutz: no set mapped to '$bucket' — staying on '$ACTIVE_SET' (map one with: shrutz weather map $bucket <set>)"
        return
    fi
    if [[ ! -d "$WALLPAPER_BASE/$target" ]] || (( $(count_images "$WALLPAPER_BASE/$target") == 0 )); then
        save_state
        echo "shrutz: mapped set '$target' is missing or has no images — staying on '$ACTIVE_SET'"
        return
    fi
    if [[ "$ACTIVE_SET" == "$target" ]]; then
        WEATHER_LAST_SET="$target"
        save_state
        echo "shrutz: '$bucket' → '$target' is already the active set"
        return
    fi
    if [[ "$target" == "$WEATHER_LAST_SET" ]]; then
        echo "shrutz: '$bucket' → '$target' (unchanged since last weather switch — not re-triggering; use 'shrutz switch $target' to force it)"
        save_state
        return
    fi

    ACTIVE_SET="$target"
    CURRENT_INDEX=0
    WEATHER_LAST_SET="$target"
    save_state
    restart_daemon
    echo "shrutz: '$bucket' → switched to set '$target'"
}

# ── shrutz stats ──────────────────────────────────────────────
cmd_stats() {
    load_state

    local total_switches uptime_line daemon_start uptime_str
    total_switches=$(grep -c 'Switched →' "$LOG_FILE" 2>/dev/null || echo 0)

    # First log line gives us daemon birth timestamp
    daemon_start=$(grep 'shrutz started' "$LOG_FILE" 2>/dev/null | tail -1 | \
        grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | \
        tr -d '[]')

    local elapsed_secs=0
    if [[ -n "$daemon_start" ]]; then
        local start_epoch now_epoch
        start_epoch=$(date -j -f '%Y-%m-%d %H:%M:%S' "$daemon_start" '+%s' 2>/dev/null || echo 0)
        now_epoch=$(date '+%s')
        elapsed_secs=$(( now_epoch - start_epoch ))
        local h=$(( elapsed_secs / 3600 ))
        local m=$(( (elapsed_secs % 3600) / 60 ))
        uptime_str="${h}h ${m}m"
    else
        uptime_str="(unknown)"
    fi

    local total_images=0
    local set_count=0
    for dir in "$WALLPAPER_BASE"/*/; do
        [[ -d "$dir" ]] || continue
        (( set_count++ )) || true
        (( total_images += $(count_images "$dir") )) || true
    done

    local paused="false"
    (( PAUSED == 1 )) && paused="true"

    if [[ "${1:-}" == "--json" ]]; then
        STJ_UPTIME_SECS="$elapsed_secs" STJ_UPTIME_HUMAN="$uptime_str" STJ_SWITCHES="$total_switches" \
        STJ_SET_COUNT="$set_count" STJ_TOTAL_IMAGES="$total_images" STJ_ACTIVE_SET="$ACTIVE_SET" \
        STJ_PAUSED="$paused" STJ_ACTIVE_SECS="$ACTIVE_SECONDS" STJ_MINS_NEEDED="$ACTIVE_MINS" python3 << 'PYEOF'
import json, os
print(json.dumps({
    "uptime_seconds": int(os.environ['STJ_UPTIME_SECS']),
    "uptime_human": os.environ['STJ_UPTIME_HUMAN'],
    "total_switches": int(os.environ['STJ_SWITCHES']),
    "set_count": int(os.environ['STJ_SET_COUNT']),
    "total_images": int(os.environ['STJ_TOTAL_IMAGES']),
    "active_set": os.environ['STJ_ACTIVE_SET'],
    "paused": os.environ['STJ_PAUSED'] == "true",
    "active_seconds": int(os.environ['STJ_ACTIVE_SECS']),
    "active_minutes_needed": int(os.environ['STJ_MINS_NEEDED']),
}))
PYEOF
        return
    fi

    local paused_label=""
    (( PAUSED == 1 )) && paused_label=" (paused)"

    echo ""
    echo "  Daemon uptime    : $uptime_str"
    echo "  Total switches   : $total_switches"
    echo "  Active sets      : $set_count"
    echo "  Total images     : $total_images"
    echo "  Active set       : $ACTIVE_SET${paused_label}"
    echo "  Timer            : $(( ACTIVE_SECONDS / 60 ))m / ${ACTIVE_MINS}m"
    echo ""
}

# ── shrutz history ────────────────────────────────────────────
cmd_history() {
    local n="${1:-10}"
    [[ "$n" =~ ^[0-9]+$ ]] || die "Usage: shrutz history [count]"

    echo ""
    printf '  %-22s  %-6s  %s\n' "TIMESTAMP" "POS" "WALLPAPER"
    printf '  %-22s  %-6s  %s\n' "──────────────────────" "──────" "─────────────────────"

    grep 'Switched →\|next →\|prev →' "$LOG_FILE" 2>/dev/null | tail -n "$n" | \
    while IFS= read -r line; do
        local ts img pos
        ts=$(echo "$line" | grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
        pos=$(echo "$line" | grep -oE '\[[0-9]+/[0-9]+\]' | tr -d '[]')
        img=$(echo "$line" | grep -oE '\] [^ ]+\.(jpg|jpeg|png|heic|webp)' | sed 's/^\] //')
        printf '  %-22s  %-6s  %s\n' "$ts" "$pos" "$img"
    done

    echo ""
}

# ── shrutz import ──────────────────────────────────────────────
cmd_import() {
    local src="" target_set=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --set)
                shift
                target_set="${1:-}"
                [[ -z "$target_set" ]] && die "--set requires a set name"
                ;;
            *)
                src="$1"
                ;;
        esac
        shift
    done

    [[ -z "$src" ]] && die "Usage: shrutz import <path> [--set <name>]"

    load_state
    [[ -z "$target_set" ]] && target_set="$ACTIVE_SET"

    local dir="$WALLPAPER_BASE/$target_set"
    [[ -d "$dir" ]] || die "set '$target_set' does not exist"

    echo "shrutz: importing into set '$target_set'..."
    _import_into "$src" "$dir"
    refresh_init_count "$dir"
    echo "shrutz: done — $(count_images "$dir") total images in '$target_set'"
}

# Internal: copy supported images from src (file or dir) into dest dir.
_import_into() {
    local src="$1" dest="$2"
    local added=0 skipped=0 fname

    if [[ -f "$src" ]]; then
        fname=$(basename "$src")
        if [[ -f "$dest/$fname" ]]; then
            (( skipped++ )) || true
        else
            cp "$src" "$dest/$fname"
            (( added++ )) || true
        fi
    elif [[ -d "$src" ]]; then
        while IFS= read -r -d '' f; do
            fname=$(basename "$f")
            if [[ -f "$dest/$fname" ]]; then
                (( skipped++ )) || true
            else
                cp "$f" "$dest/$fname"
                (( added++ )) || true
            fi
        done < <(find "$src" -maxdepth 1 \
            \( -iname "*.jpg"  -o -iname "*.jpeg" \
            -o -iname "*.png"  -o -iname "*.heic" \
            -o -iname "*.webp" \) \
            -print0)
    else
        die "source '$src' is not a file or directory"
    fi

    echo "shrutz: $added added, $skipped skipped (duplicate filename)"
}

# ── shrutz dash ───────────────────────────────────────────────
cmd_dash() {
    # Requires a terminal. Exit cleanly on q or Ctrl-C.
    command -v tput &>/dev/null || die "tput not available — dash requires a terminal"

    local DASH_REFRESH=5
    local hide_cursor show_cursor clear_screen
    hide_cursor=$(tput civis 2>/dev/null || true)
    show_cursor=$(tput cnorm 2>/dev/null || true)
    clear_screen=$(tput clear 2>/dev/null || true)

    # Restore cursor on exit
    trap "printf '%s' \"$show_cursor\"; tput rmcup 2>/dev/null; exit 0" INT TERM EXIT

    tput smcup 2>/dev/null || true
    printf '%s' "$hide_cursor"

    while true; do
        load_state

        local wallpaper_dir="$WALLPAPER_BASE/$ACTIVE_SET"
        local total; total=$(count_images "$wallpaper_dir")
        local shuffle_flag; shuffle_flag=$(init_field "$wallpaper_dir" "shuffle")

        # Resolve current wallpaper name
        local current_name="(unknown)"
        if (( total > 0 )); then
            local files=()
            while IFS= read -r -d '' f; do
                files+=("$f")
            done < <(find "$wallpaper_dir" -maxdepth 1 \
                \( -iname "*.jpg" -o -iname "*.jpeg" \
                -o -iname "*.png" -o -iname "*.heic" \
                -o -iname "*.webp" \) \
                -print0 | sort -z)
            if (( CURRENT_INDEX < ${#files[@]} )); then
                if [[ -n "$PLAY_ORDER" && "$shuffle_flag" == "true" ]]; then
                    local order=($PLAY_ORDER)
                    current_name=$(basename "${files[${order[$CURRENT_INDEX]}]}")
                else
                    current_name=$(basename "${files[$CURRENT_INDEX]}")
                fi
            fi
        fi

        # Timer progress bar (30 chars wide)
        local filled=0 bar="" pct=0
        if (( ACTIVE_SECS_NEEDED > 0 )); then
            pct=$(( ACTIVE_SECONDS * 100 / ACTIVE_SECS_NEEDED ))
            filled=$(( ACTIVE_SECONDS * 30 / ACTIVE_SECS_NEEDED ))
        fi
        (( filled > 30 )) && filled=30
        local i
        for (( i=0; i<filled; i++ ));    do bar+="█"; done
        for (( i=filled; i<30; i++ )); do bar+="░"; done

        local mins_done=$(( ACTIVE_SECONDS / 60 ))
        local mins_left=$(( (ACTIVE_SECS_NEEDED - ACTIVE_SECONDS) / 60 ))

        # Daemon uptime
        local uptime_str="(unknown)"
        local daemon_start
        daemon_start=$(grep 'shrutz started' "$LOG_FILE" 2>/dev/null | tail -1 | \
            grep -oE '^\[[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
        if [[ -n "$daemon_start" ]]; then
            local start_epoch now_epoch elapsed
            start_epoch=$(date -j -f '%Y-%m-%d %H:%M:%S' "$daemon_start" '+%s' 2>/dev/null || echo 0)
            now_epoch=$(date '+%s')
            elapsed=$(( now_epoch - start_epoch ))
            uptime_str="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m"
        fi

        # Status tags
        local status_tags=""
        (( PAUSED == 1 )) && status_tags=" [PAUSED]"
        [[ "$shuffle_flag" == "true" ]] && status_tags+=" [SHUFFLE]"

        # Last 5 history entries
        local history_lines
        history_lines=$(grep 'Switched →\|next →\|prev →' "$LOG_FILE" 2>/dev/null | tail -5)

        # Total switches
        local total_switches
        total_switches=$(grep -c 'Switched →' "$LOG_FILE" 2>/dev/null || echo 0)

        # Draw
        printf '%s' "$clear_screen"
        printf '\n'
        printf '  ┌─────────────────────────────────────────────┐\n'
        printf '  │  shrutz dash                  %s │\n' "$(date '+%H:%M:%S')              " | cut -c1-49
        printf '  ├─────────────────────────────────────────────┤\n'
        printf '  │  %-43s│\n' ""
        printf '  │  Wallpaper : %-31s│\n' "$current_name"
        printf '  │  Set       : %-31s│\n' "$ACTIVE_SET${status_tags}"
        printf '  │  Position  : %-31s│\n' "$(( CURRENT_INDEX + 1 )) of $total"
        printf '  │  %-43s│\n' ""
        printf '  │  Timer     : [%s] %d%%%-14s│\n' "$bar" "$pct" ""
        printf '  │  Active    : %dm done / %dm to next%-9s│\n' "$mins_done" "$mins_left" ""
        printf '  │  Uptime    : %-31s│\n' "$uptime_str"
        printf '  │  Switches  : %-31s│\n' "$total_switches total"
        printf '  │  %-43s│\n' ""
        printf '  ├─────────────────────────────────────────────┤\n'
        printf '  │  Recent history                             │\n'
        printf '  │  %-43s│\n' ""
        if [[ -z "$history_lines" ]]; then
            printf '  │  %-43s│\n' "(no switches yet)"
        else
            while IFS= read -r line; do
                local ts img pos
                ts=$(echo "$line" | grep -oE '\[[0-9]{2}:[0-9]{2}:[0-9]{2}\]' | tr -d '[]')
                pos=$(echo "$line" | grep -oE '\[[0-9]+/[0-9]+\]' | tr -d '[]')
                img=$(echo "$line" | grep -oE '[^ /]+\.(jpg|jpeg|png|heic|webp)')
                local entry="$ts  $pos  $img"
                printf '  │  %-43s│\n' "${entry:0:43}"
            done <<< "$history_lines"
        fi
        printf '  │  %-43s│\n' ""
        printf '  └─────────────────────────────────────────────┘\n'
        printf '\n  Press q to exit\n'

        # Non-blocking read for q
        local key=""
        IFS= read -r -s -n1 -t "$DASH_REFRESH" key 2>/dev/null || true
        [[ "$key" == "q" || "$key" == "Q" ]] && break
    done

    printf '%s' "$show_cursor"
    tput rmcup 2>/dev/null || true
}

# ── shrutz export ─────────────────────────────────────────────
cmd_export() {
    local name="${1:-}" dest="${2:-$HOME/Desktop}"
    [[ -z "$name" ]] && die "Usage: shrutz export <set> [destination]"

    local dir="$WALLPAPER_BASE/$name"
    [[ -d "$dir" ]] || die "set '$name' does not exist"
    [[ -d "$dest" ]] || die "destination '$dest' does not exist"

    local outfile="$dest/${name}.zip"
    echo "shrutz: exporting set '$name' to $outfile..."

    # zip the set directory; -j junks the paths so zip contains flat files
    # but we want to preserve the __init__ alongside images, so use -r with subdir
    (cd "$WALLPAPER_BASE" && zip -r "$outfile" "$name/" -x "*.DS_Store") || \
        die "zip failed — is zip installed?"

    local size
    size=$(du -sh "$outfile" | cut -f1)
    echo "shrutz: exported $size → $outfile"
}

# ── shrutz gallery (Creators Publish) ──────────────────────────
cmd_gallery() {
    local subcmd="${1:-list}"
    (( $# > 0 )) && shift
    case "$subcmd" in
        list)    cmd_gallery_list "$@" ;;
        install) cmd_gallery_install "$@" ;;
        *) die "Usage: shrutz gallery <list|install> [args]" ;;
    esac
}

_gallery_fetch_manifest() {
    http_get "$GALLERY_MANIFEST_URL" 15
}

cmd_gallery_list() {
    local json_mode=0
    [[ "${1:-}" == "--json" ]] && json_mode=1

    local manifest
    manifest=$(_gallery_fetch_manifest) || \
        die "could not reach the gallery manifest ($GALLERY_MANIFEST_URL) — check your network connection and try again"

    if (( json_mode == 1 )); then
        local installed_names=""
        for d in "$WALLPAPER_BASE"/*/; do
            [[ -d "$d" ]] || continue
            installed_names+="$(basename "$d")"$'\n'
        done
        GALLERY_JSON="$manifest" GALLERY_INSTALLED="$installed_names" python3 << 'PYEOF' || die "gallery manifest could not be parsed"
import json, os

data = json.loads(os.environ['GALLERY_JSON'])
installed = set(os.environ.get('GALLERY_INSTALLED', '').splitlines())
out = []
for s in data.get('sets', []):
    out.append({
        "name": s.get('name', ''),
        "author": s.get('author', ''),
        "description": s.get('description', ''),
        "images": s.get('images', 0),
        "thumbnail_url": s.get('thumbnail_url', ''),
        "installed": s.get('name', '') in installed,
    })
print(json.dumps(out))
PYEOF
        return
    fi

    local rows
    rows=$(GALLERY_JSON="$manifest" python3 << 'PYEOF'
import json, os, sys
try:
    data = json.loads(os.environ['GALLERY_JSON'])
    for s in data.get('sets', []):
        print(f"{s.get('name','')}\t{s.get('author','')}\t{s.get('images',0)}\t{s.get('description','')}")
except Exception as e:
    print(f"error: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
    ) || die "gallery manifest could not be parsed"

    echo ""
    printf '  %-20s  %-14s  %-8s  %-10s  %s\n' "NAME" "AUTHOR" "IMAGES" "INSTALLED" "DESCRIPTION"
    printf '  %-20s  %-14s  %-8s  %-10s\n' "────────────────────" "──────────────" "────────" "──────────"
    while IFS=$'\t' read -r name author images desc; do
        [[ -z "$name" ]] && continue
        local mark="no"
        [[ -d "$WALLPAPER_BASE/$name" ]] && mark="yes"
        printf '  %-20s  %-14s  %-8s  %-10s  %s\n' "$name" "$author" "$images" "$mark" "$desc"
    done <<< "$rows"
    echo ""
    echo "  Install with: shrutz gallery install <name>"
    echo ""
}

cmd_gallery_install() {
    local name="${1:-}" local_name=""
    [[ -z "$name" ]] && die "Usage: shrutz gallery install <name> [--as <local-name>]"
    shift
    while (( $# > 0 )); do
        case "$1" in
            --as) local_name="${2:-}"; shift 2 ;;
            *) die "Usage: shrutz gallery install <name> [--as <local-name>]" ;;
        esac
    done
    local_name="${local_name:-$name}"

    local dest="$WALLPAPER_BASE/$local_name"
    [[ -e "$dest" ]] && die "set '$local_name' already exists — use --as <name> or 'shrutz set delete $local_name' first"

    local manifest
    manifest=$(_gallery_fetch_manifest) || \
        die "could not reach the gallery manifest ($GALLERY_MANIFEST_URL) — check your network connection and try again"

    local entry
    entry=$(GALLERY_JSON="$manifest" GALLERY_NAME="$name" python3 << 'PYEOF'
import json, os
data = json.loads(os.environ['GALLERY_JSON'])
name = os.environ['GALLERY_NAME']
for s in data.get('sets', []):
    if s.get('name') == name:
        print(f"URL={s.get('download_url','')}")
        print(f"SHA={s.get('sha256','')}")
        break
PYEOF
    ) || die "gallery manifest could not be parsed"
    [[ -z "$entry" ]] && die "no gallery entry named '$name' — run 'shrutz gallery list' to see available sets"

    local url sha
    url=$(echo "$entry" | grep '^URL=' | cut -d= -f2-)
    sha=$(echo "$entry"  | grep '^SHA=' | cut -d= -f2-)
    [[ -z "$url" ]] && die "gallery entry '$name' has no download URL yet"

    local tmp_zip
    tmp_zip=$(mktemp "${TMPDIR:-/tmp}/shrutz-gallery-XXXXXX.zip")
    trap 'rm -f "$tmp_zip"' EXIT

    echo "shrutz: downloading '$name'..."
    http_get "$url" 30 > "$tmp_zip" || die "download failed for '$name' — check your network connection and try again"

    if [[ -n "$sha" ]]; then
        local actual
        actual=$(shasum -a 256 "$tmp_zip" | awk '{print $1}')
        [[ "$actual" == "$sha" ]] || die "checksum mismatch for '$name' — download may be corrupt, try again"
    fi

    mkdir -p "$dest"
    if ! ZIP_PATH="$tmp_zip" ZIP_DEST_DIR="$dest" python3 << 'PYEOF'
import os, sys, zipfile

zip_path = os.environ['ZIP_PATH']
dest_dir = os.environ['ZIP_DEST_DIR']

try:
    with zipfile.ZipFile(zip_path) as zf:
        names = zf.namelist()
        if not names:
            print("error: zip is empty", file=sys.stderr)
            sys.exit(1)

        # Every member is expected to be prefixed with one top-level
        # directory (the shape `shrutz export` produces) — strip that one
        # leading component so contents land directly in dest_dir
        # regardless of what the zip's internal folder was named.
        def strip_top(member):
            parts = member.split('/', 1)
            return parts[1] if len(parts) == 2 else parts[0]

        dest_real = os.path.realpath(dest_dir)

        # Validate every path BEFORE extracting anything (mandatory
        # zip-slip guard): reject any member whose resolved path escapes
        # dest_dir.
        for member in names:
            if member.endswith('/'):
                continue
            rel = strip_top(member)
            if not rel:
                continue
            target = os.path.realpath(os.path.join(dest_real, rel))
            if os.path.commonpath([dest_real, target]) != dest_real:
                print(f"error: unsafe path in zip: {member}", file=sys.stderr)
                sys.exit(1)

        for member in names:
            if member.endswith('/'):
                continue
            rel = strip_top(member)
            if not rel:
                continue
            target = os.path.join(dest_real, rel)
            os.makedirs(os.path.dirname(target), exist_ok=True)
            with zf.open(member) as src, open(target, 'wb') as out:
                out.write(src.read())

    print('ok')
except Exception as e:
    print(f'error: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
    then
        rm -rf "$dest"
        die "failed to extract gallery zip for '$name' — it may be corrupt"
    fi

    rm -f "$tmp_zip"
    trap - EXIT

    # Preserve the shuffle flag from the extracted __init__ (if any), then
    # restamp created=/images= exactly like a locally-created set — a
    # gallery-installed set becomes indistinguishable from a hand-made one.
    local shuffle_flag
    shuffle_flag=$(init_field "$dest" "shuffle")
    write_init "$dest" "$local_name"
    [[ "$shuffle_flag" == "true" ]] && printf 'shuffle=true\n' >> "$dest/__init__"

    local count
    count=$(count_images "$dest")
    echo "shrutz: installed '$local_name' ($count images) — switch to it with: shrutz switch $local_name"
}

# ── shrutz update ─────────────────────────────────────────────
cmd_update() {
    load_state

    [[ -z "$SHRUTZ_REPO" ]] && die "repo path unknown — reinstall shrutz to register SHRUTZ_REPO"
    [[ -d "$SHRUTZ_REPO/.git" ]] || die "SHRUTZ_REPO '$SHRUTZ_REPO' is not a git repository"

    echo "shrutz: pulling latest from $SHRUTZ_REPO..."
    git -C "$SHRUTZ_REPO" pull || die "git pull failed"

    echo "shrutz: running installer..."
    bash "$SHRUTZ_REPO/install.sh"

    # Installer restarts the daemon; preserve SHRUTZ_REPO in state
    # (install.sh will re-seed it, but belt-and-suspenders)
    echo "shrutz: update complete"
}

# ── shrutz menubar ─────────────────────────────────────────────
# Opt-in only — never invoked by install.sh, since not everyone wants a
# GUI helper running. Builds the companion menu bar app from source and
# places it in ~/Applications, ad-hoc signed (no Apple Developer account
# needed), matching how the CLI itself is only ever built/copied locally.
cmd_menubar() {
    local subcmd="${1:-}"
    case "$subcmd" in
        install) cmd_menubar_install ;;
        *) die "Usage: shrutz menubar install" ;;
    esac
}

cmd_menubar_install() {
    load_state

    [[ -z "$SHRUTZ_REPO" ]] && die "repo path unknown — reinstall shrutz to register SHRUTZ_REPO"
    local project_dir="$SHRUTZ_REPO/menubar"
    [[ -d "$project_dir/ShrutzMenuBar.xcodeproj" ]] || die "no ShrutzMenuBar.xcodeproj found in $project_dir"

    command -v xcodebuild &>/dev/null || \
        die "xcodebuild not found — install Xcode (or the Command Line Tools) to build the menu bar app"

    local build_dir
    build_dir=$(mktemp -d "${TMPDIR:-/tmp}/shrutz-menubar-build-XXXXXX")
    echo "shrutz: building ShrutzMenuBar..."
    ( cd "$project_dir" && xcodebuild -project ShrutzMenuBar.xcodeproj -scheme ShrutzMenuBar \
        -configuration Release -derivedDataPath "$build_dir" build ) \
        || die "build failed — see output above"

    local built_app="$build_dir/Build/Products/Release/ShrutzMenuBar.app"
    [[ -d "$built_app" ]] || die "build succeeded but ShrutzMenuBar.app was not found at the expected path"

    mkdir -p "$HOME/Applications"
    local dest_app="$HOME/Applications/ShrutzMenuBar.app"
    rm -rf "$dest_app"
    cp -R "$built_app" "$dest_app"
    rm -rf "$build_dir"

    echo "shrutz: installed → $dest_app"
    open "$dest_app"
    echo "shrutz: launched. Look for the icon in your menu bar — enable "
    echo "        \"Launch at Login\" from its Preferences if you'd like."
}

# ── shrutz dieanddontcomeback [--ever|-e] ─────────────────────
cmd_dieanddontcomeback() {
    local full=0
    [[ "${1:-}" == "--ever" || "${1:-}" == "-e" ]] && full=1

    if (( full == 0 )); then
        # Soft delete — binary only
        printf 'really? '
        read -r answer
        local answer_lower; answer_lower=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
        [[ "$answer_lower" == *yes* ]] || { echo "shrutz: fine, staying."; exit 0; }

        # Stop the daemon first so launchd doesn't restart a ghost
        launchctl unload "$LAUNCHAGENT_PLIST" 2>/dev/null || true

        rm -f "$SHRUTZ_BIN"
        echo "shrutz: binary removed. your wallpapers and sets are untouched."
        echo "shrutz: to finish the job: shrutz dieanddontcomeback --ever"
        echo "shrutz: (you'll need to run that from the repo directly now)"

    else
        # Full wipe — no going back
        printf 'really? '
        read -r answer
        local answer_lower; answer_lower=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
        [[ "$answer_lower" == *yes* ]] || { echo "shrutz: fine, staying."; exit 0; }

        echo "shrutz: stopping daemon..."
        launchctl unload "$LAUNCHAGENT_PLIST" 2>/dev/null || true

        echo "shrutz: removing files..."
        rm -f  "$SHRUTZ_BIN"
        rm -f  "$LAUNCHAGENT_PLIST"
        rm -f  "$HOME/.local/etc/launchd/local.shrutz.plist"
        rm -f  "$HOME/.local/share/man/man1/shrutz.1"
        rm -rf "$HOME/.local/lib/shrutz"

        echo "shrutz: cleaning shell config..."
        for RC in "$HOME/.zshrc" "$HOME/.bashrc"; do
            [[ -f "$RC" ]] || continue
            # Remove PATH line added by installer
            sed -i '' '/# Added by shrutz installer/d' "$RC" 2>/dev/null || true
            sed -i '' '/\.local\/bin.*PATH/d'           "$RC" 2>/dev/null || true
            sed -i '' '/local\/share\/man.*MANPATH/d'   "$RC" 2>/dev/null || true
        done

        echo "shrutz: gone. your wallpapers were in ~/.local/lib/shrutz/wallpapers/ — also gone."
        echo "shrutz: goodbye."
    fi
}

