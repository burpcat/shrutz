import json, os
print(json.dumps({
    "loaded": os.environ['SJ_LOADED'] == "true",
    "pid": int(os.environ['SJ_PID']),
    "last_exit_status": int(os.environ['SJ_EXIT']),
}))
PYEOF
        return
    fi

    launchctl list | grep shrutz || echo "shrutz: daemon not running"
}

