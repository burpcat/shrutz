#!/usr/bin/env bash
# ┌─────────────────────────────────────────────────────────────┐
# │  shrutz — active-time wallpaper rotator                     │
# │                                                             │
# │  Script  : ~/.local/bin/shrutz                             │
# │  Walls   : ~/.local/lib/shrutz/wallpapers/                 │
# │  State   : ~/.local/lib/shrutz/state                       │
# │  Log     : ~/.local/lib/shrutz/shrutz.log                  │
# │  Agent   : ~/.local/etc/launchd/local.shrutz.plist         │
# │            (symlinked → ~/Library/LaunchAgents/)           │
# └─────────────────────────────────────────────────────────────┘

# ── Paths ──────────────────────────────────────────────────────
SHRUTZ_LIB="$HOME/.local/lib/shrutz"
WALLPAPER_DIR="$SHRUTZ_LIB/wallpapers"
STATE_FILE="$SHRUTZ_LIB/state"
LOG_FILE="$SHRUTZ_LIB/shrutz.log"
WALLPAPER_STORE="$HOME/Library/Application Support/com.apple.wallpaper/Store/Index.plist"

# ── Tunables ───────────────────────────────────────────────────
ACTIVE_MINS=30        # minutes of real use before switching
IDLE_THRESHOLD=60     # seconds without input → considered away
CHECK_EVERY=30        # how often the loop wakes up (seconds)

# ── Derived ────────────────────────────────────────────────────
ACTIVE_SECS_NEEDED=$(( ACTIVE_MINS * 60 ))

# ── Logging ────────────────────────────────────────────────────
log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

# ── Build wallpaper list ────────────────────────────────────────
WALLPAPERS=()
while IFS= read -r -d '' f; do
    WALLPAPERS+=("$f")
done < <(find "$WALLPAPER_DIR" -maxdepth 1 \
    \( -iname "*.jpg"  -o -iname "*.jpeg" \
    -o -iname "*.png"  -o -iname "*.heic" \
    -o -iname "*.webp" \) \
    -print0 | sort -z)

TOTAL=${#WALLPAPERS[@]}
if (( TOTAL == 0 )); then
    log "ERROR: no images found in $WALLPAPER_DIR — exiting"
    exit 1
fi

# ── Load state ─────────────────────────────────────────────────
CURRENT_INDEX=0
ACTIVE_SECONDS=0
if [[ -f "$STATE_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$STATE_FILE"
fi
(( CURRENT_INDEX >= TOTAL )) && CURRENT_INDEX=0

# ── Helpers ────────────────────────────────────────────────────

idle_seconds() {
    ioreg -c IOHIDSystem \
        | awk '/HIDIdleTime/ { print int($NF / 1000000000); exit }'
}

# Read what is actually showing on the active Space right now.
current_wallpaper() {
    osascript -e \
        'tell application "System Events" to get picture of desktop 1' \
        2>/dev/null | tr -d '\n'
}

# Fast apply to the currently visible Space on every display.
# Used for mismatch corrections — no agent restart needed.
apply_to_current_space() {
    local path="$1"
    osascript -e \
        "tell application \"System Events\"
            tell every desktop
                set picture to \"$path\"
            end tell
        end tell" 2>/dev/null
}

# Write the new wallpaper path into every Space entry inside
# Index.plist, then restart the wallpaper agent so it re-reads
# the store and propagates the change to all Mission Control Spaces.
#
# How Index.plist works (macOS 14+):
#   The file lives at:
#     ~/Library/Application Support/com.apple.wallpaper/Store/Index.plist
#   It is a binary plist with four top-level keys:
#     AllSpacesAndDisplays  — idle/screensaver config (we leave this alone)
#     SystemDefault         — fallback config for unassigned spaces
#     Spaces                — dict keyed by Space UUID; each Space has:
#                               Default    → the Space-level wallpaper
#                               Displays   → per-display overrides within the Space
#     Displays              — top-level display configs
#
#   The image path is NOT in the `Files` array (always empty).
#   It is inside the `Configuration` field, which is itself a binary
#   plist with shape:
#     { 'type': 'imageFile', 'url': { 'relative': 'file:///path/to/img' } }
#
#   We rebuild that inner plist with the new path and write it back.
#   The wallpaper agent is restarted via launchctl so it picks up the
#   changes across all Spaces without requiring a full logout.
#
# Path is passed via WP_PATH env var to keep bash quoting simple and
# handle filenames with spaces or special characters safely.
write_index_plist() {
    local path="$1"
    local store="$WALLPAPER_STORE"

    WP_PATH="$path" WP_STORE="$store" python3 << 'PYEOF'
import plistlib, datetime, os, sys

path  = os.environ['WP_PATH']
store = os.environ['WP_STORE']

# Build the inner Configuration binary plist for this image path
config = plistlib.dumps(
    {'type': 'imageFile', 'url': {'relative': f'file://{path}'}},
    fmt=plistlib.FMT_BINARY
)
now = datetime.datetime.now()

def patch_desktop(desktop):
    """Rewrite the Configuration blob and touch LastSet on a Desktop entry."""
    content = desktop.get('Content', {})
    for choice in content.get('Choices', []):
        # Only touch image choices — leave idle/video/dynamic entries alone
        if choice.get('Provider') == 'com.apple.wallpaper.choice.image':
            choice['Configuration'] = config
            choice['Files'] = []
    desktop['LastSet'] = now

def patch_space(space):
    """Update Default and every Display override within a Space."""
    default = space.get('Default', {})
    if 'Desktop' in default:
        patch_desktop(default['Desktop'])
    for disp in space.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

try:
    with open(store, 'rb') as f:
        d = plistlib.load(f)

    # SystemDefault — fallback for any Space not explicitly listed
    if 'Desktop' in d.get('SystemDefault', {}):
        patch_desktop(d['SystemDefault']['Desktop'])

    # Every named Space
    for space in d.get('Spaces', {}).values():
        patch_space(space)

    # Top-level Displays (cover display-level overrides outside a Space)
    for disp in d.get('Displays', {}).values():
        if 'Desktop' in disp:
            patch_desktop(disp['Desktop'])

    with open(store, 'wb') as f:
        plistlib.dump(d, f, fmt=plistlib.FMT_BINARY)

    print('ok')
except Exception as e:
    print(f'error: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
}

apply_all_spaces() {
    local path="$1"

    if [[ ! -f "$WALLPAPER_STORE" ]]; then
        # Store absent — old macOS or unusual setup; fall back to AppleScript
        apply_to_current_space "$path"
        log "Wallpaper store not found — applied to current space only (poll will correct others)"
        return
    fi

    if write_index_plist "$path"; then
        # Restart the wallpaper agent so it re-reads Index.plist.
        # launchctl kickstart -k kills the running instance and starts a fresh one.
        # The gui/<uid>/ prefix targets the per-user launchd domain (not system-wide).
        launchctl kickstart -k "gui/$(id -u)/com.apple.wallpaper.agent" 2>/dev/null || \
            killall WallpaperAgent 2>/dev/null || true
        sleep 1
        # Belt-and-suspenders: also set via AppleScript for the active Space
        apply_to_current_space "$path"
        log "Applied to all spaces via Index.plist + agent reload"
    else
        apply_to_current_space "$path"
        log "Index.plist write failed — applied to current space only (poll will correct others)"
    fi
}

save_state() {
    printf 'CURRENT_INDEX=%d\nACTIVE_SECONDS=%d\n' \
        "$CURRENT_INDEX" "$ACTIVE_SECONDS" > "$STATE_FILE"
}

# ── Boot ───────────────────────────────────────────────────────
log "shrutz started — $TOTAL wallpapers, rotate every ${ACTIVE_MINS}m active use"
apply_all_spaces "${WALLPAPERS[$CURRENT_INDEX]}"
log "Restored → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "${WALLPAPERS[$CURRENT_INDEX]}")"

# ── Main loop ──────────────────────────────────────────────────
while true; do
    sleep "$CHECK_EVERY"

    idle=$(idle_seconds)

    if (( idle < IDLE_THRESHOLD )); then
        # ── User is active ──────────────────────────────────────
        (( ACTIVE_SECONDS += CHECK_EVERY ))

        if (( ACTIVE_SECONDS >= ACTIVE_SECS_NEEDED )); then
            # ── Time to advance ─────────────────────────────────
            # Full apply: write Index.plist so every Space gets updated.
            (( CURRENT_INDEX = (CURRENT_INDEX + 1) % TOTAL ))
            apply_all_spaces "${WALLPAPERS[$CURRENT_INDEX]}"
            ACTIVE_SECONDS=0
            log "Switched → [$(( CURRENT_INDEX + 1 ))/$TOTAL] $(basename "${WALLPAPERS[$CURRENT_INDEX]}")"

        else
            # ── Not yet time — poll the active Space ────────────
            # Catches a Space that missed a previous Index.plist write,
            # or where the agent reload hadn't propagated yet.
            # Fast AppleScript only — no plist write, no agent restart.
            expected="${WALLPAPERS[$CURRENT_INDEX]}"
            current=$(current_wallpaper)
            if [[ "$current" != "$expected" ]]; then
                apply_to_current_space "$expected"
                log "Mismatch on active space — reapplied: $(basename "$expected")"
            fi
        fi

    fi
    # idle >= IDLE_THRESHOLD: user is away, timer and poll both pause

    save_state
done
